<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="d-flex justify-content-center align-items-start py-4">
  <div class="w-100" style="max-width: 680px;">

    <!-- Header -->
    <div class="text-center mb-4">
      <div class="env-icon-wrap mx-auto mb-3">
        <i class="bi bi-thermometer-half fs-1 text-white"></i>
      </div>
      <h3 class="fw-bold text-dark mb-1">ตรวจสภาพแวดล้อมห้อง Server</h3>
      <p class="text-muted small">ตรวจสภาพห้อง • ตู้ Rack • ระบบแอร์ทำความเย็น / UPS / PDU</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger border-0 shadow-sm small mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
      </div>
    <% } %>

    <!-- Start Form -->
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
      <h6 class="fw-bold text-dark mb-3"><i class="bi bi-play-circle text-teal me-2"></i>เริ่มรอบตรวจใหม่</h6>

      <%
        const hasReachedLimit = sessionCount >= limit;
      %>
      <% if (hasReachedLimit) { %>
        <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-warning-emphasis small mb-3">
          <i class="bi bi-info-circle-fill me-2"></i>วันนี้ตรวจครบโควตา <strong><%= limit %> รอบ/วัน</strong> แล้ว หากต้องการแก้ไขให้เปิดรอบเก่าด้านล่าง
        </div>
      <% } %>

      <form action="/env-inspections/start" method="POST">
        <div class="mb-3">
          <label for="roomId" class="form-label fw-semibold small text-muted">เลือกห้อง Server ที่จะตรวจ</label>
          <select class="form-select" id="roomId" name="roomId" required <%= hasReachedLimit ? 'disabled' : '' %>>
            <option value="">-- เลือกห้อง Server --</option>
            <% rooms.forEach(r => { %>
              <option value="<%= r.id %>"><%= r.room_name %></option>
            <% }); %>
          </select>
        </div>
        <button type="submit" id="btn-start-env"
          class="btn btn-teal btn-lg w-100 py-2 rounded-3 fw-bold d-flex align-items-center justify-content-center gap-2"
          <%= hasReachedLimit ? 'disabled' : '' %>>
          <i class="bi bi-play-fill fs-4"></i> เริ่มตรวจสภาพแวดล้อม
        </button>
      </form>
    </div>

    <!-- Today sessions list -->
    <% if (todaySessions && todaySessions.length > 0) { %>
      <div class="card border-0 shadow-sm rounded-4 p-4">
        <h6 class="fw-bold text-dark mb-3"><i class="bi bi-clock-history text-teal me-2"></i>รอบตรวจของวันนี้</h6>
        <div class="d-flex flex-column gap-2">
          <% todaySessions.forEach((sess, idx) => { %>
            <div class="inspection-card <%= sess.overall_status === 'fail' ? 'fail' :
                                            sess.overall_status === 'warning' ? 'warning' :
                                            sess.overall_status === 'pass' ? 'pass' : 'in_progress' %>">
              <div>
                <span class="fw-bold text-dark d-block mb-1">
                  รอบที่ <%= idx + 1 %> (#<%= sess.id %>) — <span class="text-teal"><%= sess.room_name %></span>
                </span>
                <div class="text-muted" style="font-size:0.82rem;">
                  <span class="me-3"><i class="bi bi-person me-1"></i><%= sess.inspector_name %></span>
                  <span><i class="bi bi-play me-1"></i><%= formatThaiDate(sess.started_at, true) %></span>
                </div>
              </div>
              <div class="text-end">
                <% if (sess.status === 'completed') { %>
                  <% if (sess.overall_status === 'pass') { %>
                    <span class="badge bg-success rounded-pill mb-1"><i class="bi bi-check-circle-fill me-1"></i>ผ่าน</span>
                  <% } else if (sess.overall_status === 'warning') { %>
                    <span class="badge bg-warning text-dark rounded-pill mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>เฝ้าระวัง</span>
                  <% } else if (sess.overall_status === 'fail') { %>
                    <span class="badge bg-danger rounded-pill mb-1"><i class="bi bi-x-circle-fill me-1"></i>พบปัญหา</span>
                  <% } %>
                  <br>
                  <form action="/env-inspections/reopen" method="POST" class="mt-1">
                    <input type="hidden" name="sessionId" value="<%= sess.id %>">
                    <button type="submit" class="btn btn-sm btn-outline-teal px-3 fw-bold rounded-2">
                      <i class="bi bi-pencil-square"></i> แก้ไข
                    </button>
                  </form>
                <% } else { %>
                  <span class="badge bg-warning-subtle text-warning-emphasis px-3 py-2 rounded-pill">
                    <i class="bi bi-hourglass-split me-1"></i>กำลังตรวจ
                  </span>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <div class="text-center mt-3">
      <a href="/env-inspections/history" class="btn btn-link text-muted small">
        <i class="bi bi-clock-history me-1"></i>ดูประวัติการตรวจทั้งหมด
      </a>
    </div>

  </div>
</div>

<style>
.env-icon-wrap {
  width: 80px; height: 80px;
  background: linear-gradient(135deg, #0d9488, #0ea5e9);
  border-radius: 24px;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8px 24px rgba(13,148,136,0.3);
}
.btn-teal { background: linear-gradient(135deg, #0d9488, #0ea5e9); color: #fff; border: none; }
.btn-teal:hover { background: linear-gradient(135deg, #0f766e, #0284c7); color: #fff; }
.btn-teal:disabled { background: #94a3b8; }
.btn-outline-teal { border: 1.5px solid #0d9488; color: #0d9488; }
.btn-outline-teal:hover { background: #0d9488; color: #fff; }
.text-teal { color: #0d9488; }

/* Clean high-contrast cards */
.inspection-card {
  background-color: #ffffff !important;
  border: 1px solid #e2e8f0 !important;
  border-left: 5px solid #cbd5e1 !important;
  border-radius: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem;
  transition: all 0.2s ease;
}
.inspection-card.pass { border-left-color: #198754 !important; }
.inspection-card.warning { border-left-color: #ffc107 !important; }
.inspection-card.fail { border-left-color: #dc3545 !important; }
.inspection-card.in_progress { border-left-color: #0dcaf0 !important; }
.inspection-card.pending { border-left-color: #6b7280 !important; }

</style>

<%- include('../layouts/footer') %>

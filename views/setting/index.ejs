<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <div>
    <h1 class="h2 fw-bold text-dark">System Settings</h1>
    <p class="text-muted small">ระบบบริหารจัดการและตั้งค่าพารามิเตอร์ของระบบ</p>
  </div>
  <div class="btn-toolbar mb-2 mb-md-0 gap-2">
    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#addModal">
      <i class="bi bi-plus-lg"></i> เพิ่มพารามิเตอร์ใหม่
    </button>
    <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#importModal">
      <i class="bi bi-file-earmark-arrow-up"></i> นำเข้า CSV
    </button>
    <a href="/settings/export?search=<%= search %>" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
      <i class="bi bi-file-earmark-arrow-down"></i> ส่งออก CSV
    </a>
  </div>
</div>

<!-- Alerts -->
<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- LINE Notify Settings Card -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-body p-4">
    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-line text-success me-2"></i>ตั้งค่าระบบแจ้งเตือนทาง LINE (MOPH Line Notify)</h5>
    <form action="/settings/notifications" method="POST" id="lineNotifyForm">
      <div class="row g-3">
        <!-- Client Key -->
        <div class="col-12 col-md-6 col-lg-4">
          <label for="line_client_key" class="form-label small fw-semibold text-muted">MOPH Notify Client Key</label>
          <input type="text" class="form-control font-monospace" id="line_client_key" name="line_client_key" value="<%= notifySettings.clientKey %>" required>
        </div>
        <!-- Secret Key -->
        <div class="col-12 col-md-6 col-lg-4">
          <label for="line_secret_key" class="form-label small fw-semibold text-muted">MOPH Notify Secret Key</label>
          <input type="text" class="form-control font-monospace" id="line_secret_key" name="line_secret_key" value="<%= notifySettings.secretKey %>" required>
        </div>
        <!-- Notification Time -->
        <div class="col-6 col-md-3 col-lg-2">
          <label for="notification_time" class="form-label small fw-semibold text-muted">เวลาสรุปประจำวัน</label>
          <input type="time" class="form-control" id="notification_time" name="notification_time" value="<%= notifySettings.notificationTime %>" required>
        </div>
        <!-- Enabled Toggle -->
        <div class="col-6 col-md-3 col-lg-2">
          <label for="is_notification_enabled" class="form-label small fw-semibold text-muted">สถานะการเตือน</label>
          <select class="form-select" id="is_notification_enabled" name="is_notification_enabled">
            <option value="1" <%= notifySettings.isEnabled ? 'selected' : '' %>>เปิดใช้งาน</option>
            <option value="0" <%= !notifySettings.isEnabled ? 'selected' : '' %>>ปิดใช้งาน</option>
          </select>
        </div>
        <!-- Action Buttons -->
        <div class="col-12 d-flex gap-2 justify-content-end mt-2">
          <button type="button" onclick="testLineConnection()" class="btn btn-outline-success fw-semibold"><i class="bi bi-send-fill me-1.5"></i>ทดสอบส่งข้อความ LINE</button>
          <button type="submit" class="btn btn-primary px-4 fw-semibold"><i class="bi bi-save me-1.5"></i>บันทึกการตั้งค่า</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Search bar -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-body">
    <form method="GET" action="/settings" class="row g-2 align-items-center">
      <div class="col-md-9 col-lg-10">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
          <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="ค้นหาพารามิเตอร์ หรือคำอธิบาย..." value="<%= search %>">
        </div>
      </div>
      <div class="col-md-3 col-lg-2 d-grid">
        <button type="submit" class="btn btn-dark">ค้นหา</button>
      </div>
    </form>
  </div>
</div>

<!-- Main Table -->
<div class="card border-0 shadow-sm rounded-4 p-4">
  <div class="table-responsive">
    <table class="table align-middle table-hover">
      <thead class="table-light">
        <tr>
          <th>Key (รหัสอ้างอิง)</th>
          <th>Value (ค่าพารามิเตอร์)</th>
          <th>คำอธิบายรายละเอียด</th>
          <th>วันที่บันทึก</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (settings.length > 0) { %>
          <% settings.forEach(set => { %>
            <tr>
              <td><span class="fw-semibold text-primary"><code><%= set.setting_key %></code></span></td>
              <td><strong><%= set.setting_value %></strong></td>
              <td class="text-muted small"><%= set.description || '-' %></td>
              <td class="small text-muted"><%= formatThaiDate(set.created_at, false) %></td>
              <td>
                <div class="d-flex gap-2">
                  <button class="btn btn-sm btn-outline-warning" 
                          data-bs-toggle="modal" 
                          data-bs-target="#editModal" 
                          data-id="<%= set.id %>"
                          data-setting_key="<%= set.setting_key %>"
                          data-setting_value="<%= set.setting_value %>"
                          data-description="<%= set.description %>"
                          onclick="populateEditModal(this)">
                    <i class="bi bi-pencil"></i> แก้ไข
                  </button>
                  <button class="btn btn-sm btn-outline-danger" 
                          data-bs-toggle="modal" 
                          data-bs-target="#deleteModal" 
                          data-id="<%= set.id %>"
                          data-name="<%= set.setting_key %>"
                          onclick="confirmDelete(this)">
                    <i class="bi bi-trash"></i> ลบ
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="text-center text-muted py-4">ไม่พบข้อมูลการตั้งค่าในระบบ</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
    <nav aria-label="Page navigation" class="mt-4">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&page=<%= pagination.page - 1 %>">ย้อนกลับ</a>
        </li>
        <% for(let i=1; i<=pagination.totalPages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&page=<%= pagination.page + 1 %>">ถัดไป</a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addModalLabel">เพิ่มตั้งค่าพารามิเตอร์</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/settings" method="POST" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="setting_key" class="form-label small fw-semibold">Setting Key *</label>
            <input type="text" class="form-control" id="setting_key" name="setting_key" placeholder="เช่น system_name" required>
            <div class="invalid-feedback">กรุณาระบุรหัส Setting Key</div>
          </div>
          <div class="mb-3">
            <label for="setting_value" class="form-label small fw-semibold">Setting Value *</label>
            <input type="text" class="form-control" id="setting_value" name="setting_value" placeholder="ระบุค่าพารามิเตอร์" required>
            <div class="invalid-feedback">กรุณาระบุค่าพารามิเตอร์</div>
          </div>
          <div class="mb-2">
            <label for="description" class="form-label small fw-semibold">คำอธิบาย</label>
            <textarea class="form-control" id="description" name="description" rows="2" placeholder="จุดประสงค์การตั้งค่า..."></textarea>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-primary px-4">บันทึกข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="editModalLabel">แก้ไขพารามิเตอร์</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editForm" method="POST" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="edit_setting_key" class="form-label small fw-semibold">Setting Key *</label>
            <input type="text" class="form-control" id="edit_setting_key" name="setting_key" required>
            <div class="invalid-feedback">กรุณาระบุรหัส Setting Key</div>
          </div>
          <div class="mb-3">
            <label for="edit_setting_value" class="form-label small fw-semibold">Setting Value *</label>
            <input type="text" class="form-control" id="edit_setting_value" name="setting_value" required>
            <div class="invalid-feedback">กรุณาระบุค่าพารามิเตอร์</div>
          </div>
          <div class="mb-2">
            <label for="edit_description" class="form-label small fw-semibold">คำอธิบาย</label>
            <textarea class="form-control" id="edit_description" name="description" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-warning px-4">บันทึกการแก้ไข</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="deleteModalLabel">ยืนยันการลบ?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="deleteForm" method="POST">
        <div class="modal-body py-3">
          <p class="text-muted small mb-0">คุณแน่ใจหรือไม่ว่าต้องการลบพารามิเตอร์ <strong id="deleteItemName" class="text-dark"></strong>? การลบนี้ไม่สามารถกู้คืนข้อมูลได้</p>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-3" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-danger px-3">ลบข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="importModalLabel">นำเข้าข้อมูลด้วยไฟล์ CSV</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/settings/import" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="csvFile" class="form-label small fw-semibold">เลือกไฟล์ CSV *</label>
            <input class="form-control" type="file" id="csvFile" name="file" accept=".csv" required>
            <div class="invalid-feedback">กรุณาเลือกไฟล์ CSV ที่ต้องการนำเข้า</div>
          </div>
          <div class="p-3 bg-light rounded-3 border">
            <h6 class="fw-bold fs-7 mb-2">โครงสร้างหัวตารางที่ถูกต้องของไฟล์ CSV (Headers):</h6>
            <code class="small d-block text-dark">setting_key,setting_value,description</code>
            <span class="d-block text-muted fs-8 mt-2">* หมายเหตุ: ฟิลด์ setting_key และ setting_value ห้ามเว้นว่าง</span>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-success px-4">เริ่มนำเข้าข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict'
  var forms = document.querySelectorAll('.needs-validation')
  Array.prototype.slice.call(forms)
    .forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
})()

function populateEditModal(btn) {
  const id = btn.getAttribute('data-id');
  document.getElementById('editForm').action = '/settings/' + id + '/update';
  document.getElementById('edit_setting_key').value = btn.getAttribute('data-setting_key');
  document.getElementById('edit_setting_value').value = btn.getAttribute('data-setting_value');
  document.getElementById('edit_description').value = btn.getAttribute('data-description') || '';
}

function confirmDelete(btn) {
  const id = btn.getAttribute('data-id');
  const name = btn.getAttribute('data-name');
  document.getElementById('deleteForm').action = '/settings/' + id + '/delete';
  document.getElementById('deleteItemName').innerText = name;
}

function testLineConnection() {
  const clientKey = document.getElementById('line_client_key').value.trim();
  const secretKey = document.getElementById('line_secret_key').value.trim();
  
  if (!clientKey || !secretKey) {
    Swal.fire({
      title: 'ข้อมูลไม่ครบถ้วน',
      text: 'กรุณากรอก Client Key และ Secret Key ของ MOPH Notify ก่อนกดทดสอบ',
      icon: 'warning'
    });
    return;
  }

  Swal.fire({
    title: 'กำลังทดสอบ...',
    text: 'ระบบกำลังส่งข้อความทดลองไปยัง LINE ของคุณ',
    allowOutsideClick: false,
    didOpen: () => {
      Swal.showLoading();
    }
  });

  fetch('/settings/notifications/test', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      line_client_key: clientKey,
      line_secret_key: secretKey
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      Swal.fire({
        title: 'สำเร็จ!',
        text: 'ส่งข้อความทดสอบเข้า LINE เรียบร้อยแล้ว กรุณาตรวจสอบห้องแชทของคุณ',
        icon: 'success'
      });
    } else {
      Swal.fire({
        title: 'ล้มเหลว',
        text: 'ไม่สามารถเชื่อมต่อได้: ' + (data.error || 'Unknown error'),
        icon: 'error'
      });
    }
  })
  .catch(err => {
    Swal.fire({
      title: 'ผิดพลาด',
      text: 'เกิดปัญหาเครือข่าย: ' + err.message,
      icon: 'error'
    });
  });
}
</script>

<%- include('../layouts/footer') %>

<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <div>
    <h1 class="h2 fw-bold text-dark">Users Management</h1>
    <p class="text-muted small">ระบบบริหารจัดการข้อมูลผู้ใช้งานและผู้มีสิทธิ์ตรวจเช็คระบบ</p>
  </div>
  <div class="btn-toolbar mb-2 mb-md-0 gap-2">
    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#addModal">
      <i class="bi bi-person-plus-fill"></i> เพิ่มผู้ใช้งาน
    </button>
    <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#importModal">
      <i class="bi bi-file-earmark-arrow-up"></i> นำเข้า CSV
    </button>
    <a href="/users/export?search=<%= search %>" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
      <i class="bi bi-file-earmark-arrow-down"></i> ส่งออก CSV
    </a>
  </div>
</div>

<!-- Alerts -->
<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- Search bar -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-body">
    <form method="GET" action="/users" class="row g-2 align-items-center">
      <div class="col-md-9 col-lg-10">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
          <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="ค้นหาด้วย username, ชื่อ-นามสกุล, อีเมล หรือสิทธิ์ผู้ใช้..." value="<%= search %>">
        </div>
      </div>
      <div class="col-md-3 col-lg-2 d-grid">
        <button type="submit" class="btn btn-dark">ค้นหา</button>
      </div>
    </form>
  </div>
</div>

<!-- Main Table -->
<div class="card border-0 shadow-sm rounded-4 p-4">
  <div class="table-responsive">
    <table class="table align-middle table-hover">
      <thead class="table-light">
        <tr>
          <th>ชื่อผู้ใช้งาน (Username)</th>
          <th>ชื่อ-นามสกุลจริง</th>
          <th>สิทธิ์เข้าใช้งาน</th>
          <th>อีเมล</th>
          <th>สถานะ</th>
          <th>วันที่สร้าง</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length > 0) { %>
          <% users.forEach(usr => { %>
            <tr>
              <td><span class="fw-semibold text-primary"><%= usr.username %></span></td>
              <td><%= usr.name %></td>
              <td><span class="badge bg-secondary"><%= usr.role_name %></span></td>
              <td><code><%= usr.email %></code></td>
              <td>
                <% if(usr.is_active === 1) { %>
                  <span class="badge bg-success">Active</span>
                <% } else { %>
                  <span class="badge bg-danger">Inactive</span>
                <% } %>
              </td>
              <td class="small text-muted"><%= formatThaiDate(usr.created_at, false) %></td>
              <td>
                <div class="d-flex gap-2">
                  <button class="btn btn-sm btn-outline-warning" 
                          data-bs-toggle="modal" 
                          data-bs-target="#editModal" 
                          data-id="<%= usr.id %>"
                          data-username="<%= usr.username %>"
                          data-role_id="<%= usr.role_id %>"
                          data-name="<%= usr.name %>"
                          data-email="<%= usr.email %>"
                          data-is_active="<%= usr.is_active %>"
                          onclick="populateEditModal(this)">
                    <i class="bi bi-pencil"></i> แก้ไข
                  </button>
                  <!-- Prevent self-deletion if logged in -->
                  <button class="btn btn-sm btn-outline-danger" 
                          data-bs-toggle="modal" 
                          data-bs-target="#deleteModal" 
                          data-id="<%= usr.id %>"
                          data-name="<%= usr.username %>"
                          onclick="confirmDelete(this)">
                    <i class="bi bi-trash"></i> ลบ
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="text-center text-muted py-4">ไม่พบข้อมูลผู้ใช้งานในระบบ</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
    <nav aria-label="Page navigation" class="mt-4">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&page=<%= pagination.page - 1 %>">ย้อนกลับ</a>
        </li>
        <% for(let i=1; i<=pagination.totalPages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&page=<%= pagination.page + 1 %>">ถัดไป</a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addModalLabel">เพิ่มผู้ใช้งาน</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/users" method="POST" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="row g-2 mb-3">
            <div class="col">
              <label for="username" class="form-label small fw-semibold">Username *</label>
              <input type="text" class="form-control" id="username" name="username" required>
              <div class="invalid-feedback">กรุณาระบุ Username</div>
            </div>
            <div class="col">
              <label for="password" class="form-label small fw-semibold">Password *</label>
              <input type="password" class="form-control" id="password" name="password" required>
              <div class="invalid-feedback">กรุณาระบุรหัสผ่าน</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="role_id" class="form-label small fw-semibold">สิทธิ์เข้าใช้งานระบบ *</label>
            <select class="form-select" id="role_id" name="role_id" required>
              <option value="">-- เลือกสิทธิ์ --</option>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>"><%= role.role_name %></option>
              <% }) %>
            </select>
            <div class="invalid-feedback">กรุณาเลือกสิทธิ์การใช้งาน</div>
          </div>

          <div class="mb-3">
            <label for="name" class="form-label small fw-semibold">ชื่อ-นามสกุลจริง *</label>
            <input type="text" class="form-control" id="name" name="name" required>
            <div class="invalid-feedback">กรุณาระบุชื่อ-นามสกุล</div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-8">
              <label for="email" class="form-label small fw-semibold">อีเมลติดต่อ *</label>
              <input type="email" class="form-control" id="email" name="email" required>
              <div class="invalid-feedback">กรุณาระบุอีเมลที่ถูกต้อง</div>
            </div>
            <div class="col-4">
              <label for="is_active" class="form-label small fw-semibold">สถานะเปิดใช้ *</label>
              <select class="form-select" id="is_active" name="is_active" required>
                <option value="1" selected>Active</option>
                <option value="0">Inactive</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-primary px-4">บันทึกข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="editModalLabel">แก้ไขผู้ใช้งาน</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editForm" method="POST" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="row g-2 mb-3">
            <div class="col">
              <label for="edit_username" class="form-label small fw-semibold">Username *</label>
              <input type="text" class="form-control" id="edit_username" name="username" required>
              <div class="invalid-feedback">กรุณาระบุ Username</div>
            </div>
            <div class="col">
              <label for="edit_password" class="form-label small fw-semibold">Password ใหม่ (เว้นว่างหากไม่เปลี่ยน)</label>
              <input type="password" class="form-control" id="edit_password" name="password">
            </div>
          </div>

          <div class="mb-3">
            <label for="edit_role_id" class="form-label small fw-semibold">สิทธิ์เข้าใช้งานระบบ *</label>
            <select class="form-select" id="edit_role_id" name="role_id" required>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>"><%= role.role_name %></option>
              <% }) %>
            </select>
            <div class="invalid-feedback">กรุณาเลือกสิทธิ์การใช้งาน</div>
          </div>

          <div class="mb-3">
            <label for="edit_name" class="form-label small fw-semibold">ชื่อ-นามสกุลจริง *</label>
            <input type="text" class="form-control" id="edit_name" name="name" required>
            <div class="invalid-feedback">กรุณาระบุชื่อ-นามสกุล</div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-8">
              <label for="edit_email" class="form-label small fw-semibold">อีเมลติดต่อ *</label>
              <input type="email" class="form-control" id="edit_email" name="email" required>
              <div class="invalid-feedback">กรุณาระบุอีเมลที่ถูกต้อง</div>
            </div>
            <div class="col-4">
              <label for="edit_is_active" class="form-label small fw-semibold">สถานะเปิดใช้ *</label>
              <select class="form-select" id="edit_is_active" name="is_active" required>
                <option value="1">Active</option>
                <option value="0">Inactive</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-warning px-4">บันทึกการแก้ไข</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="deleteModalLabel">ยืนยันการลบ?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="deleteForm" method="POST">
        <div class="modal-body py-3">
          <p class="text-muted small mb-0">คุณแน่ใจหรือไม่ว่าต้องการลบผู้ใช้งาน <strong id="deleteItemName" class="text-dark"></strong>? การลบนี้ไม่สามารถกู้คืนข้อมูลได้</p>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-3" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-danger px-3">ลบข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="importModalLabel">นำเข้าข้อมูลด้วยไฟล์ CSV</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/users/import" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="csvFile" class="form-label small fw-semibold">เลือกไฟล์ CSV *</label>
            <input class="form-control" type="file" id="csvFile" name="file" accept=".csv" required>
            <div class="invalid-feedback">กรุณาเลือกไฟล์ CSV ที่ต้องการนำเข้า</div>
          </div>
          <div class="p-3 bg-light rounded-3 border text-break">
            <h6 class="fw-bold fs-7 mb-2">โครงสร้างหัวตารางที่ถูกต้องของไฟล์ CSV (Headers):</h6>
            <code class="small d-block text-dark">username,password,role_id,name,email,is_active</code>
            <span class="d-block text-muted fs-8 mt-2">* หมายเหตุ: ทุกช่องยกเว้น is_active ห้ามเว้นว่าง (role_id ต้องมีอยู่จริงในระบบ)</span>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-success px-4">เริ่มนำเข้าข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict'
  var forms = document.querySelectorAll('.needs-validation')
  Array.prototype.slice.call(forms)
    .forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
})()

function populateEditModal(btn) {
  const id = btn.getAttribute('data-id');
  document.getElementById('editForm').action = '/users/' + id + '/update';
  document.getElementById('edit_username').value = btn.getAttribute('data-username');
  document.getElementById('edit_role_id').value = btn.getAttribute('data-role_id');
  document.getElementById('edit_name').value = btn.getAttribute('data-name');
  document.getElementById('edit_email').value = btn.getAttribute('data-email');
  document.getElementById('edit_is_active').value = btn.getAttribute('data-is_active');
  document.getElementById('edit_password').value = ''; // clear password input field
}

function confirmDelete(btn) {
  const id = btn.getAttribute('data-id');
  const name = btn.getAttribute('data-name');
  document.getElementById('deleteForm').action = '/users/' + id + '/delete';
  document.getElementById('deleteItemName').innerText = name;
}
</script>

<%- include('../layouts/footer') %>

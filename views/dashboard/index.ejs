<!-- TRENDS CHARTS SECTION (30 DAYS & 12 MONTHS) -->
<div class="row g-4 mb-4">
  <!-- 30 Days Trend -->
  <div class="col-12 col-xl-6">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h5 class="fw-bold text-dark mb-3"><i class="bi bi-calendar3 text-primary me-2"></i>ประวัติการตรวจย้อนหลัง 30 วัน</h5>
      <div id="chart30Days" style="height: 350px; width: 100%;"></div>
    </div>
  </div>

  <!-- 12 Months Trend -->
  <div class="col-12 col-xl-6">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h5 class="fw-bold text-dark mb-3"><i class="bi bi-calendar-range text-primary me-2"></i>ประวัติการตรวจย้อนหลัง 12 เดือน</h5>
      <div id="chart12Months" style="height: 350px; width: 100%;"></div>
    </div>
  </div>
</div>

<!-- PIE CHART & TOP RISK ANALYSIS -->
<div class="row g-4 mb-4">
  <!-- Checklist Item Results Pie Chart -->
  <div class="col-12 col-lg-5">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h5 class="fw-bold text-dark mb-3"><i class="bi bi-pie-chart text-primary me-2"></i>สัดส่วนผลลัพธ์ข้อคำถามตรวจเช็ค</h5>
      <div id="chartChecklistPie" style="height: 320px; width: 100%;"></div>
    </div>
  </div>

  <!-- Top Risk Analysis Lists -->
  <div class="col-12 col-lg-7">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h5 class="fw-bold text-dark mb-3"><i class="bi bi-shield-alert text-danger me-2"></i>จุดเสี่ยงสะสม (วิเคราะห์ความผิดปกติบ่อยสุด)</h5>
      
      <ul class="nav nav-pills nav-justified mb-3 bg-light p-1 rounded-3" id="riskTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active py-2 rounded-3 text-dark small fw-semibold" id="rooms-tab" data-bs-toggle="pill" data-bs-target="#tab-rooms" type="button" role="tab" aria-controls="tab-rooms" aria-selected="true">
            <i class="bi bi-door-closed me-1"></i>ห้องพักเซิร์ฟเวอร์
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link py-2 rounded-3 text-dark small fw-semibold" id="racks-tab" data-bs-toggle="pill" data-bs-target="#tab-racks" type="button" role="tab" aria-controls="tab-racks" aria-selected="false">
            <i class="bi bi-hdd-rack me-1"></i>ตู้แร็ค (Rack)
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link py-2 rounded-3 text-dark small fw-semibold" id="servers-tab" data-bs-toggle="pill" data-bs-target="#tab-servers" type="button" role="tab" aria-controls="tab-servers" aria-selected="false">
            <i class="bi bi-pc-display-horizontal me-1"></i>เครื่องเซิร์ฟเวอร์
          </button>
        </li>
      </ul>
      
      <div class="tab-content" id="riskTabsContent">
        <!-- Top Rooms Tab -->
        <div class="tab-pane fade show active" id="tab-rooms" role="tabpanel" aria-labelledby="rooms-tab">
          <div class="list-group list-group-flush" id="topRoomsList">
            <div class="text-center text-muted py-5"><i class="bi bi-check2-circle text-success fs-1 mb-2 d-block"></i>ไม่พบรายงานความผิดปกติในห้องเซิร์ฟเวอร์ในช่วงนี้</div>
          </div>
        </div>
        
        <!-- Top Racks Tab -->
        <div class="tab-pane fade" id="tab-racks" role="tabpanel" aria-labelledby="racks-tab">
          <div class="list-group list-group-flush" id="topRacksList">
            <div class="text-center text-muted py-5"><i class="bi bi-check2-circle text-success fs-1 mb-2 d-block"></i>ไม่พบรายงานความผิดปกติในตู้แร็คในช่วงนี้</div>
          </div>
        </div>

        <!-- Top Servers Tab -->
        <div class="tab-pane fade" id="tab-servers" role="tabpanel" aria-labelledby="servers-tab">
          <div class="list-group list-group-flush" id="topServersList">
            <div class="text-center text-muted py-5"><i class="bi bi-check2-circle text-success fs-1 mb-2 d-block"></i>ไม่พบรายงานความผิดปกติในเครื่องเซิร์ฟเวอร์ในช่วงนี้</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- LATEST INSPECTION HISTORY — with Physical/VM tabs -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-clock-history text-primary me-2"></i>สถานะรอบการตรวจเช็คล่าสุด</h5>
  </div>

  <!-- Tab Navigation -->
  <ul class="nav nav-pills nav-fill bg-light p-1 rounded-3 mb-3" id="sessionTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active rounded-3 text-dark small fw-semibold" id="physical-tab" data-bs-toggle="pill" data-bs-target="#tab-physical" type="button">
        <i class="bi bi-pc-display-horizontal me-1"></i>Physical Server
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link rounded-3 text-dark small fw-semibold" id="vm-tab" data-bs-toggle="pill" data-bs-target="#tab-vm" type="button">
        <i class="bi bi-cpu me-1"></i>Virtual Machines (VM)
      </button>
    </li>
  </ul>

  <div class="tab-content" id="sessionTabsContent">
    <!-- Physical Sessions Tab -->
    <div class="tab-pane fade show active" id="tab-physical" role="tabpanel">
      <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
          <thead class="table-light"><tr>
            <th>รหัสรอบ</th><th>วันที่และเวลา</th><th>ผู้ตรวจสอบ</th>
            <th>ผลการตรวจ</th><th>สถานะ</th><th class="text-center">จัดการ</th>
          </tr></thead>
          <tbody>
            <% if (summary.latestSessions && summary.latestSessions.length > 0) { %>
              <% summary.latestSessions.forEach(sess => { %>
                <tr>
                  <td><span class="fw-bold">#<%= sess.session_id %></span></td>
                  <td><%= formatThaiDate(sess.started_at, true) %></td>
                  <td><strong><%= sess.inspector_name %></strong></td>
                  <td>
                    <div class="d-flex gap-1">
                      <% if (sess.pass_count > 0) { %><span class="badge bg-success-subtle text-success border border-success-subtle">ปกติ: <%= sess.pass_count %></span><% } %>
                      <% if (sess.warning_count > 0) { %><span class="badge bg-warning-subtle text-warning border border-warning-subtle">เตือน: <%= sess.warning_count %></span><% } %>
                      <% if (sess.fail_count > 0) { %><span class="badge bg-danger-subtle text-danger border border-danger-subtle">ผิดปกติ: <%= sess.fail_count %></span><% } %>
                      <% if (sess.pass_count === 0 && sess.warning_count === 0 && sess.fail_count === 0) { %><span class="text-muted small">-</span><% } %>
                    </div>
                  </td>
                  <td>
                    <% if (sess.session_status === 'completed') { %><span class="badge bg-success rounded-pill"><i class="bi bi-check-circle-fill me-1"></i>เสร็จสมบูรณ์</span>
                    <% } else if (sess.session_status === 'in_progress') { %><span class="badge bg-warning text-dark rounded-pill"><i class="bi bi-hourglass-split me-1"></i>กำลังตรวจ</span><% } %>
                  </td>
                  <td class="text-center">
                    <% if (sess.session_status === 'completed') { %>
                      <form action="/inspections/reopen" method="POST" class="d-inline">
                        <input type="hidden" name="sessionId" value="<%= sess.session_id %>">
                        <button type="submit" class="btn btn-xs btn-outline-primary py-1 px-2 rounded-2 small fw-semibold"><i class="bi bi-pencil-square"></i> แก้ไข</button>
                      </form>
                    <% } else if (sess.session_status === 'in_progress' && user.id === sess.inspector_id) { %>
                      <a href="/inspections/walk" class="btn btn-xs btn-primary py-1 px-2 rounded-2 small fw-semibold"><i class="bi bi-play-fill"></i> ตรวจต่อ</a>
                    <% } else { %><span class="text-muted small">-</span><% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="6" class="text-center py-4 text-muted">ไม่พบข้อมูลการเดินตรวจเช็คในระบบ</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- VM Sessions Tab -->
    <div class="tab-pane fade" id="tab-vm" role="tabpanel">
      <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
          <thead class="table-light"><tr>
            <th>รหัสรอบ</th><th>วันที่และเวลา</th><th>ผู้ตรวจสอบ</th>
            <th>ผลการตรวจ VM</th><th>สถานะ</th><th class="text-center">จัดการ</th>
          </tr></thead>
          <tbody>
            <% if (summary.vmLatestSessions && summary.vmLatestSessions.length > 0) { %>
              <% summary.vmLatestSessions.forEach(sess => { %>
                <tr>
                  <td><span class="fw-bold text-info">#<%= sess.session_id %></span> <span class="badge bg-info-subtle text-info border border-info-subtle ms-1" style="font-size:0.6rem;">VM</span></td>
                  <td><%= formatThaiDate(sess.started_at, true) %></td>
                  <td><strong><%= sess.inspector_name %></strong></td>
                  <td>
                    <div class="d-flex gap-1">
                      <% if (sess.pass_count > 0) { %><span class="badge bg-success-subtle text-success border border-success-subtle">ปกติ: <%= sess.pass_count %></span><% } %>
                      <% if (sess.warning_count > 0) { %><span class="badge bg-warning-subtle text-warning border border-warning-subtle">เตือน: <%= sess.warning_count %></span><% } %>
                      <% if (sess.fail_count > 0) { %><span class="badge bg-danger-subtle text-danger border border-danger-subtle">ผิดปกติ: <%= sess.fail_count %></span><% } %>
                      <% if (sess.pass_count === 0 && sess.warning_count === 0 && sess.fail_count === 0) { %><span class="text-muted small">-</span><% } %>
                    </div>
                  </td>
                  <td>
                    <% if (sess.session_status === 'completed') { %><span class="badge bg-success rounded-pill"><i class="bi bi-check-circle-fill me-1"></i>เสร็จสมบูรณ์</span>
                    <% } else if (sess.session_status === 'in_progress') { %><span class="badge bg-warning text-dark rounded-pill"><i class="bi bi-hourglass-split me-1"></i>กำลังตรวจ</span><% } %>
                  </td>
                  <td class="text-center">
                    <% if (sess.session_status === 'completed') { %>
                      <form action="/inspections/vm-reopen" method="POST" class="d-inline">
                        <input type="hidden" name="sessionId" value="<%= sess.session_id %>">
                        <button type="submit" class="btn btn-xs btn-outline-info py-1 px-2 rounded-2 small fw-semibold"><i class="bi bi-pencil-square"></i> แก้ไข</button>
                      </form>
                    <% } else if (sess.session_status === 'in_progress') { %>
                      <a href="/inspections/vm-walk" class="btn btn-xs btn-info text-white py-1 px-2 rounded-2 small fw-semibold"><i class="bi bi-play-fill"></i> ตรวจต่อ</a>
                    <% } else { %><span class="text-muted small">-</span><% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="6" class="text-center py-4 text-muted">ไม่พบข้อมูลการตรวจ VM ในระบบ</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
  

<style>
/* Dashboard Styles & Animations */
.card-hover {
  transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}
.card-hover:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08) !important;
}

/* ── Status Row Component ── */
.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.55rem 0.75rem;
  border-radius: 8px;
  border-left: 3.5px solid transparent;
  transition: background 0.15s ease, transform 0.15s ease;
  position: relative;
}
.stat-row::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0.75rem;
  right: 0.75rem;
  height: 1px;
  background: linear-gradient(to right, currentColor 0%, transparent 100%);
  opacity: 0.12;
}
.stat-row:last-child::after { display: none; }

.stat-row:hover {
  transform: translateX(2px);
}

/* Pass – green */
.stat-row--pass {
  border-left-color: #198754;
  color: #198754;
}
.stat-row--pass:hover { background: rgba(25, 135, 84, 0.06); }
.stat-row--pass .stat-label { color: #198754; }
.stat-row--pass .stat-value { color: #198754; font-weight: 700; font-size: 1.05rem; }

/* Warning – amber */
.stat-row--warning {
  border-left-color: #e09c00;
  color: #e09c00;
}
.stat-row--warning:hover { background: rgba(255, 193, 7, 0.08); }
.stat-row--warning .stat-label { color: #997000; }
.stat-row--warning .stat-value { color: #e09c00; font-weight: 700; font-size: 1.05rem; }

/* Fail – red */
.stat-row--fail {
  border-left-color: #dc3545;
  color: #dc3545;
}
.stat-row--fail:hover { background: rgba(220, 53, 69, 0.06); }
.stat-row--fail .stat-label { color: #dc3545; }
.stat-row--fail .stat-value { color: #dc3545; font-weight: 700; font-size: 1.05rem; }

/* Pending – slate */
.stat-row--pending {
  border-left-color: #adb5bd;
  color: #6c757d;
}
.stat-row--pending:hover { background: rgba(108, 117, 125, 0.06); }
.stat-row--pending .stat-label { color: #6c757d; }
.stat-row--pending .stat-value { color: #6c757d; font-weight: 600; font-size: 1.05rem; }

/* Shared label style */
.stat-label {
  font-size: 0.84rem;
  font-weight: 500;
  display: flex;
  align-items: center;
}

.fs-8.5 {
  font-size: 0.85rem !important;
}
.fs-9 {
  font-size: 0.75rem !important;
}
.fs-7.5 {
  font-size: 1.1rem !important;
}
.btn-xs {
  font-size: 0.75rem;
  padding: 0.25rem 0.5rem;
}
.simple-chart {
  height: 100%;
  overflow: auto;
  padding: 0.25rem 0.5rem 0.5rem;
}
.simple-chart-row {
  display: grid;
  grid-template-columns: 86px 1fr 42px;
  align-items: center;
  gap: 0.75rem;
  min-height: 28px;
  font-size: 0.78rem;
}
.simple-chart-label {
  color: #64748b;
  white-space: nowrap;
}
.simple-chart-track {
  display: flex;
  height: 12px;
  overflow: hidden;
  background: #e5e7eb;
  border-radius: 999px;
}
.simple-bar {
  display: block;
  min-width: 0;
}
.simple-bar-pass {
  background: #198754;
}
.simple-bar-warning {
  background: #f59f00;
}
.simple-bar-fail {
  background: #dc3545;
}
.simple-chart-total {
  color: #334155;
  font-weight: 700;
  text-align: right;
}

</style>

<script>
const embeddedAnalytics = <%- JSON.stringify(summary.analytics || {
  dailyTrends: [],
  monthlyTrends: [],
  checklistDistribution: [],
  topRooms: [],
  topRacks: [],
  topServers: []
}) %>;

document.addEventListener("DOMContentLoaded", function() {
  renderDashboardAnalytics(embeddedAnalytics);

  fetch('/dashboard/api/analytics')
    .then(res => {
      const contentType = res.headers.get('content-type') || '';
      if (!res.ok || !contentType.includes('application/json')) {
        throw new Error('Analytics API did not return JSON');
      }
      return res.json();
    })
    .then(data => {
      renderDashboardAnalytics(data);
    })
    .catch(err => {
      console.error('Error loading analytics charts:', err);
    });
});

function renderDashboardAnalytics(data = {}) {
  render30DaysChart(data.dailyTrends || []);
  render12MonthsChart(data.monthlyTrends || []);
  renderPieChart(data.checklistDistribution || []);
  renderRiskLists(data.topRooms || [], data.topRacks || [], data.topServers || []);
}

function canUseEcharts() {
  return typeof echarts !== 'undefined' && echarts && typeof echarts.init === 'function';
}

function showChartNotice(chartDom, message) {
  chartDom.innerHTML = `
    <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted text-center">
      <i class="bi bi-info-circle fs-1 mb-2 text-primary"></i>
      <div class="fw-semibold">${message}</div>
    </div>
  `;
}

function renderSimpleTrend(chartDom, rows, labelKey) {
  if (!rows.length) {
    showChartNotice(chartDom, 'ยังไม่มีข้อมูลสำหรับช่วงเวลานี้');
    return;
  }

  const maxValue = Math.max(1, ...rows.map(row =>
    Number(row.pass_count || 0) + Number(row.warning_count || 0) + Number(row.fail_count || 0)
  ));

  chartDom.innerHTML = `
    <div class="simple-chart">
      ${rows.map(row => {
        const pass = Number(row.pass_count || 0);
        const warning = Number(row.warning_count || 0);
        const fail = Number(row.fail_count || 0);
        const total = pass + warning + fail;
        const label = labelKey === 'month' ? row.month : row.date;
        return `
          <div class="simple-chart-row">
            <div class="simple-chart-label">${label}</div>
            <div class="simple-chart-track">
              <span class="simple-bar simple-bar-pass" style="width:${(pass / maxValue) * 100}%"></span>
              <span class="simple-bar simple-bar-warning" style="width:${(warning / maxValue) * 100}%"></span>
              <span class="simple-bar simple-bar-fail" style="width:${(fail / maxValue) * 100}%"></span>
            </div>
            <div class="simple-chart-total">${total}</div>
          </div>
        `;
      }).join('')}
    </div>
  `;
}

function renderSimplePie(chartDom, dist) {
  let pass = 0, fail = 0, na = 0;
  dist.forEach(d => {
    if (d.result_value === 'pass') pass = Number(d.count);
    else if (d.result_value === 'fail') fail = Number(d.count);
    else if (d.result_value === 'na') na = Number(d.count);
  });

  const total = pass + fail + na;
  if (!total) {
    showChartNotice(chartDom, 'ยังไม่มีข้อมูลผลลัพธ์ข้อคำถาม');
    return;
  }

  chartDom.innerHTML = `
    <div class="h-100 d-flex flex-column justify-content-center gap-3">
      <div class="d-flex justify-content-between align-items-center"><span class="text-success fw-semibold">ปกติ (Pass)</span><span>${pass} ข้อ</span></div>
      <div class="progress" style="height:12px;"><div class="progress-bar bg-success" style="width:${(pass / total) * 100}%"></div></div>
      <div class="d-flex justify-content-between align-items-center"><span class="text-danger fw-semibold">ผิดปกติ (Fail)</span><span>${fail} ข้อ</span></div>
      <div class="progress" style="height:12px;"><div class="progress-bar bg-danger" style="width:${(fail / total) * 100}%"></div></div>
      <div class="d-flex justify-content-between align-items-center"><span class="text-secondary fw-semibold">N/A</span><span>${na} ข้อ</span></div>
      <div class="progress" style="height:12px;"><div class="progress-bar bg-secondary" style="width:${(na / total) * 100}%"></div></div>
    </div>
  `;
}

// Render 30 Days Trend Bar Chart
function render30DaysChart(trends) {
  const chartDom = document.getElementById('chart30Days');
  trends = Array.isArray(trends) ? trends : [];

  if (!canUseEcharts()) {
    renderSimpleTrend(chartDom, trends, 'date');
    return;
  }

  const myChart = echarts.init(chartDom);
  
  const dates = trends.map(t => {
    const d = new Date(t.date);
    return `${d.getDate()} / ${d.getMonth() + 1}`;
  });
  const pass = trends.map(t => Number(t.pass_count));
  const warning = trends.map(t => Number(t.warning_count));
  const fail = trends.map(t => Number(t.fail_count));

  const option = {
    tooltip: {
      trigger: 'axis',
      axisPointer: { type: 'shadow' }
    },
    legend: {
      data: ['ปกติ (Pass)', 'เฝ้าระวัง (Warning)', 'ผิดปกติ (Fail)'],
      bottom: 0
    },
    grid: {
      top: '8%',
      left: '3%',
      right: '4%',
      bottom: '12%',
      containLabel: true
    },
    xAxis: {
      type: 'category',
      data: dates
    },
    yAxis: {
      type: 'value',
      minInterval: 1
    },
    color: ['#198754', '#ffc107', '#dc3545'],
    series: [
      { name: 'ปกติ (Pass)', type: 'bar', stack: 'total', data: pass },
      { name: 'เฝ้าระวัง (Warning)', type: 'bar', stack: 'total', data: warning },
      { name: 'ผิดปกติ (Fail)', type: 'bar', stack: 'total', data: fail }
    ]
  };

  myChart.setOption(option);
  window.addEventListener('resize', myChart.resize);
}

// Render 12 Months Trend Bar/Line Chart
function render12MonthsChart(trends) {
  const chartDom = document.getElementById('chart12Months');
  trends = Array.isArray(trends) ? trends : [];

  if (!canUseEcharts()) {
    renderSimpleTrend(chartDom, trends, 'month');
    return;
  }

  const myChart = echarts.init(chartDom);

  const months = trends.map(t => {
    const [year, month] = t.month.split('-');
    const monthNames = ["ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
    return `${monthNames[parseInt(month) - 1]} ${year.slice(2)}`;
  });
  const pass = trends.map(t => Number(t.pass_count));
  const warning = trends.map(t => Number(t.warning_count));
  const fail = trends.map(t => Number(t.fail_count));

  const option = {
    tooltip: {
      trigger: 'axis',
      axisPointer: { type: 'shadow' }
    },
    legend: {
      data: ['ปกติ (Pass)', 'เฝ้าระวัง (Warning)', 'ผิดปกติ (Fail)'],
      bottom: 0
    },
    grid: {
      top: '8%',
      left: '3%',
      right: '4%',
      bottom: '12%',
      containLabel: true
    },
    xAxis: {
      type: 'category',
      data: months
    },
    yAxis: {
      type: 'value',
      minInterval: 1
    },
    color: ['#198754', '#ffc107', '#dc3545'],
    series: [
      { name: 'ปกติ (Pass)', type: 'bar', stack: 'total', data: pass },
      { name: 'เฝ้าระวัง (Warning)', type: 'bar', stack: 'total', data: warning },
      { name: 'ผิดปกติ (Fail)', type: 'bar', stack: 'total', data: fail }
    ]
  };

  myChart.setOption(option);
  window.addEventListener('resize', myChart.resize);
}

// Render Checklist Item Distribution Pie Chart
function renderPieChart(dist) {
  const chartDom = document.getElementById('chartChecklistPie');
  dist = Array.isArray(dist) ? dist : [];

  if (!canUseEcharts()) {
    renderSimplePie(chartDom, dist);
    return;
  }

  const myChart = echarts.init(chartDom);

  let pass = 0, fail = 0, na = 0;
  dist.forEach(d => {
    if (d.result_value === 'pass') pass = Number(d.count);
    else if (d.result_value === 'fail') fail = Number(d.count);
    else if (d.result_value === 'na') na = Number(d.count);
  });

  const option = {
    tooltip: {
      trigger: 'item',
      formatter: '{b}: {c} ข้อ ({d}%)'
    },
    legend: {
      orient: 'horizontal',
      bottom: 0,
      left: 'center'
    },
    color: ['#198754', '#dc3545', '#6c757d'],
    series: [
      {
        name: 'สัดส่วนผลลัพธ์',
        type: 'pie',
        radius: ['40%', '70%'],
        avoidLabelOverlap: false,
        itemStyle: {
          borderRadius: 8,
          borderColor: '#fff',
          borderWidth: 2
        },
        label: {
          show: false,
          position: 'center'
        },
        emphasis: {
          label: {
            show: true,
            fontSize: 16,
            fontWeight: 'bold',
            formatter: '{b}\n{c} ({d}%)'
          }
        },
        labelLine: {
          show: false
        },
        data: [
          { value: pass, name: 'ปกติ (Pass)' },
          { value: fail, name: 'ผิดปกติ (Fail)' },
          { value: na, name: 'ไม่มี / N/A' }
        ]
      }
    ]
  };

  myChart.setOption(option);
  window.addEventListener('resize', myChart.resize);
}

// Render Top Risk Lists
function renderRiskLists(rooms, racks, servers) {
  rooms = Array.isArray(rooms) ? rooms : [];
  racks = Array.isArray(racks) ? racks : [];
  servers = Array.isArray(servers) ? servers : [];

  // Render Rooms
  const roomsList = document.getElementById('topRoomsList');
  if (rooms.length > 0) {
    roomsList.innerHTML = '';
    rooms.forEach(r => {
      roomsList.innerHTML += `
        <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-bottom">
          <div>
            <h6 class="fw-bold text-dark mb-1"><i class="bi bi-door-closed text-muted me-2"></i>${r.room_name}</h6>
            <span class="text-muted fs-9">ตรวจเช็คสะสม ${r.total_inspections} ครั้ง</span>
          </div>
          <div class="text-end">
            <span class="badge bg-danger rounded-pill px-2.5 py-1 mb-1">ผิดปกติ: ${r.fail_count} ครั้ง</span>
            ${r.warning_count > 0 ? `<br><span class="badge bg-warning text-dark rounded-pill px-2.5 py-1">เฝ้าระวัง: ${r.warning_count} ครั้ง</span>` : ''}
          </div>
        </div>
      `;
    });
  }

  // Render Racks
  const racksList = document.getElementById('topRacksList');
  if (racks.length > 0) {
    racksList.innerHTML = '';
    racks.forEach(rk => {
      racksList.innerHTML += `
        <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-bottom">
          <div>
            <h6 class="fw-bold text-dark mb-1"><i class="bi bi-hdd-rack text-muted me-2"></i>${rk.rack_name}</h6>
            <span class="text-muted fs-9">ห้อง: ${rk.room_name} | ตรวจเช็คสะสม ${rk.total_inspections} ครั้ง</span>
          </div>
          <div class="text-end">
            <span class="badge bg-danger rounded-pill px-2.5 py-1 mb-1">ผิดปกติ: ${rk.fail_count} ครั้ง</span>
            ${rk.warning_count > 0 ? `<br><span class="badge bg-warning text-dark rounded-pill px-2.5 py-1">เฝ้าระวัง: ${rk.warning_count} ครั้ง</span>` : ''}
          </div>
        </div>
      `;
    });
  }

  // Render Servers
  const serversList = document.getElementById('topServersList');
  if (servers.length > 0) {
    serversList.innerHTML = '';
    servers.forEach(srv => {
      serversList.innerHTML += `
        <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-bottom">
          <div>
            <h6 class="fw-bold text-dark mb-1"><i class="bi bi-pc-display-horizontal text-muted me-2"></i>${srv.server_name}</h6>
            <span class="text-muted fs-9">แร็ค: ${srv.rack_name} (ห้อง: ${srv.room_name}) | ตรวจเช็คสะสม ${srv.total_inspections} ครั้ง</span>
          </div>
          <div class="text-end">
            <span class="badge bg-danger rounded-pill px-2.5 py-1 mb-1">ผิดปกติ: ${srv.fail_count} ครั้ง</span>
            ${srv.warning_count > 0 ? `<br><span class="badge bg-warning text-dark rounded-pill px-2.5 py-1">เฝ้าระวัง: ${srv.warning_count} ครั้ง</span>` : ''}
          </div>
        </div>
      `;
    });
  }
}
</script>


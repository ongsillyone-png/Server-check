            <span class="stat-value"><%= summary.monthStats.fail %> เครื่อง</span>
          </div>
          <div class="stat-row stat-row--pending">
            <span class="stat-label"><i class="bi bi-clock-history me-1.5"></i>รอดำเนินการ (Pending)</span>
            <span class="stat-value"><%= summary.monthStats.pending %> เครื่อง</span>
          </div>
        </div>
      </div>
    </div>

    <!-- This Year Stats -->
    <div class="col-12 col-md-4">
      <div class="p-3 bg-light rounded-4 border h-100">
        <h6 class="fw-bold text-dark border-bottom pb-2 mb-2">ล่าสุดในปีนี้ (This Year)</h6>
        <div class="d-flex flex-column gap-1 mt-3">
          <div class="stat-row stat-row--pass">

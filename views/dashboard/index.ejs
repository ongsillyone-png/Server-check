<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<!-- ECharts Library -->
<script src="/vendor/echarts/echarts.min.js"></script>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <div>
    <h1 class="h2 fw-bold text-dark"><i class="bi bi-speedometer2 text-primary me-2"></i>หน้าแรก / สรุปภาพรวมวันนี้</h1>
    <p class="text-muted small mb-0">ระบบวิเคราะห์ ติดตามความพร้อม และประเมินสุขภาพอุปกรณ์ห้อง Server</p>
  </div>
  <div class="btn-toolbar mb-2 mb-md-0">
    <div class="btn-group me-2">
      <a href="/inspections/walk" class="btn btn-sm btn-primary d-flex align-items-center gap-1.5 px-3 py-2 fw-bold shadow-sm rounded-3">
        <i class="bi bi-clipboard2-check fs-6"></i> เริ่มเดินตรวจอุปกรณ์
      </a>
    </div>
  </div>
</div>

<!-- TOP ASSETS CARDS -->
<div class="row g-3 mb-4">
  <!-- Rooms Card -->
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm rounded-4 h-100 p-3 card-hover">
      <div class="d-flex align-items-center gap-3">
        <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3">
          <i class="bi bi-door-closed fs-3"></i>
        </div>
        <div>
          <h6 class="text-muted mb-0 small">ห้อง Server ทั้งหมด</h6>
          <h3 class="fw-bold mb-0 text-dark"><%= summary.assets.rooms %></h3>
        </div>
      </div>
    </div>
  </div>
  <!-- Racks Card -->
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm rounded-4 h-100 p-3 card-hover">
      <div class="d-flex align-items-center gap-3">
        <div class="bg-info bg-opacity-10 text-info rounded-3 p-3">
          <i class="bi bi-hdd-rack fs-3"></i>
        </div>
        <div>
          <h6 class="text-muted mb-0 small">ตู้ Rack ในระบบ</h6>
          <h3 class="fw-bold mb-0 text-dark"><%= summary.assets.racks %></h3>
        </div>
      </div>
    </div>
  </div>
  <!-- Servers Card -->
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm rounded-4 h-100 p-3 card-hover">
      <div class="d-flex align-items-center gap-3">
        <div class="bg-success bg-opacity-10 text-success rounded-3 p-3">
          <i class="bi bi-pc-display-horizontal fs-3"></i>
        </div>
        <div>
          <h6 class="text-muted mb-0 small">Physical Server</h6>
          <h3 class="fw-bold mb-0 text-dark"><%= summary.assets.servers %></h3>
        </div>
      </div>
    </div>
  </div>
  <!-- VMs Card -->
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm rounded-4 h-100 p-3 card-hover">
      <div class="d-flex align-items-center gap-3">
        <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3">
          <i class="bi bi-cpu fs-3"></i>
        </div>
        <div>
          <h6 class="text-muted mb-0 small">Virtual Machines (VM)</h6>
          <h3 class="fw-bold mb-0 text-dark"><%= summary.assets.vms %></h3>
        </div>
      </div>
    </div>
  </div>
</div>


<!-- ENVIRONMENT INSPECTION STATS CARDS -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4" style="border-left: 4px solid #0d9488 !important;">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-thermometer-half me-2" style="color:#0d9488;"></i>สรุปการตรวจสภาพแวดล้อม ห้อง SERVER วันนี้</h5>
    <a href="/env-inspections/walk" class="btn btn-sm fw-semibold rounded-3 text-white" style="background:linear-gradient(135deg,#0d9488,#0ea5e9);">
      <i class="bi bi-play-fill me-1"></i>เริ่มตรวจสภาพแวดล้อม
    </a>
  </div>
  <div class="row g-3">
    <div class="col-12 col-md-8">
      <div class="p-3 rounded-4 border h-100" style="background:#f0fdf9;">
        <h6 class="fw-bold text-dark border-bottom pb-2 mb-2 d-flex justify-content-between align-items-center">
          <span>วันนี้ (Today)</span>
          <span class="badge rounded-pill text-white" style="background:#0d9488;font-size:0.72rem;">รอบตรวจแวดล้อม</span>
        </h6>
        <div class="d-flex flex-column gap-1 mt-3">
          <div class="stat-row stat-row--pass">
            <span class="stat-label"><i class="bi bi-check-circle-fill me-1.5"></i>ผ่านการตรวจ (Pass)</span>
            <span class="stat-value"><%= summary.envStats ? summary.envStats.today_pass || 0 : 0 %> รอบ</span>
          </div>
          <div class="stat-row stat-row--warning">
            <span class="stat-label"><i class="bi bi-exclamation-triangle-fill me-1.5"></i>เฝ้าระวัง (Warning)</span>
            <span class="stat-value"><%= summary.envStats ? summary.envStats.today_warning || 0 : 0 %> รอบ</span>
          </div>
          <div class="stat-row stat-row--fail">
            <span class="stat-label"><i class="bi bi-x-circle-fill me-1.5"></i>พบปัญหา (Fail)</span>
            <span class="stat-value"><%= summary.envStats ? summary.envStats.today_fail || 0 : 0 %> รอบ</span>
          </div>
          <div class="stat-row stat-row--pending">
            <span class="stat-label"><i class="bi bi-clock-history me-1.5"></i>กำลังตรวจ (In Progress)</span>
            <span class="stat-value"><%= summary.envStats ? summary.envStats.today_pending || 0 : 0 %> รอบ</span>
          </div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4">
      <div class="p-3 rounded-4 border h-100 text-center d-flex flex-column justify-content-center align-items-center" style="background:#f0fdf9;">
        <div class="mb-2" style="color:#0d9488;"><i class="bi bi-thermometer-half fs-1"></i></div>
        <div class="text-muted small fw-semibold mb-1">อุณหภูมิเฉลี่ยวันนี้</div>
        <% const avgTemp = summary.envStats ? summary.envStats.avg_temp_today : null; %>
        <% if (avgTemp !== null && avgTemp !== undefined) { %>
          <div class="fw-bold fs-2 <%= avgTemp > 27 ? 'text-danger' : avgTemp > 24 ? 'text-warning' : 'text-success' %>">
            <%= avgTemp %>°C
          </div>
          <div class="text-muted" style="font-size:0.72rem;">มาตรฐาน ASHRAE 18–27°C</div>
        <% } else { %>
          <div class="text-muted fw-semibold">ยังไม่มีข้อมูลวันนี้</div>
          <div class="text-muted" style="font-size:0.72rem;">บันทึกค่าหลังตรวจแล้ว</div>
        <% } %>
        <a href="/env-inspections/history" class="btn btn-sm btn-outline-secondary mt-3 rounded-3 fw-semibold px-3">
          <i class="bi bi-clock-history me-1"></i>ดูประวัติ
        </a>
      </div>
    </div>
  </div>
</div>

<!-- PERIODIC INSPECTION STATS CARDS -->

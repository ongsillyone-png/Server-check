            <span class="stat-value"><%= summary.yearStats.warning %> เครื่อง</span>
          </div>
          <div class="stat-row stat-row--fail">
            <span class="stat-label"><i class="bi bi-x-circle-fill me-1.5"></i>ผิดปกติ (Fail)</span>
            <span class="stat-value"><%= summary.yearStats.fail %> เครื่อง</span>
          </div>
          <div class="stat-row stat-row--pending">
            <span class="stat-label"><i class="bi bi-clock-history me-1.5"></i>รอดำเนินการ (Pending)</span>
            <span class="stat-value"><%= summary.yearStats.pending %> เครื่อง</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>




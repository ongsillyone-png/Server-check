<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <!-- Google Fonts - Sarabun -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      border: none;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      border: 1px solid rgba(255, 255, 255, 0.1);
      width: 100%;
      max-width: 420px;
    }
  </style>
</head>
<body>

  <div class="login-card p-4 p-md-5 text-white">
    <div class="text-center mb-4">
      <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-25 rounded-circle p-3 mb-3">
        <i class="bi bi-shield-check text-success fs-1"></i>
      </div>
      <h3 class="fw-bold mb-1">Server Check</h3>
      <p class="text-white-50 small">ระบบตรวจเช็คห้อง Server โรงพยาบาล</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger d-flex align-items-center gap-2 border-0 bg-danger bg-opacity-25 text-white rounded mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill text-danger"></i>
        <div class="small"><%= error %></div>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="mb-3">
        <label for="username" class="form-label small text-white-50">Username</label>
        <div class="input-group">
          <span class="input-group-text bg-white bg-opacity-10 border-0 text-white-50"><i class="bi bi-person"></i></span>
          <input type="text" class="form-control bg-white bg-opacity-10 border-0 text-white" id="username" name="username" placeholder="กรอกชื่อผู้ใช้" required>
        </div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label small text-white-50">Password</label>
        <div class="input-group">
          <span class="input-group-text bg-white bg-opacity-10 border-0 text-white-50"><i class="bi bi-lock"></i></span>
          <input type="password" class="form-control bg-white bg-opacity-10 border-0 text-white" id="password" name="password" placeholder="กรอกรหัสผ่าน" required>
        </div>
      </div>

      <button type="submit" class="btn btn-success w-100 py-2.5 fw-semibold mb-3">เข้าสู่ระบบ</button>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <div>
    <h1 class="h2 fw-bold text-dark"><i class="bi bi-bell text-primary me-2"></i>ศูนย์การแจ้งเตือน</h1>
    <p class="text-muted small mb-0">ติดตามข่าวสารสรุปงานประจำวัน และบันทึกปัญหาความผิดปกติจากการเดินตรวจเช็ค</p>
  </div>
  <div class="btn-toolbar mb-2 mb-md-0">
    <button type="button" onclick="markAllNotificationsAsRead()" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
      <i class="bi bi-check-all fs-6"></i> อ่านทั้งหมดแล้ว
    </button>
  </div>
</div>

<!-- NOTIFICATION LIST CONTAINER -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
  <div class="list-group list-group-flush" id="notificationListGroup">
    <% if (notifications && notifications.length > 0) { %>
      <% notifications.forEach(item => { %>
        <div class="list-group-item py-3 px-2 border-bottom d-flex align-items-start justify-content-between gap-3 rounded-3 mb-2 transition-all <%= item.is_read ? 'bg-white' : 'bg-primary-subtle bg-opacity-25 border-start border-primary border-3' %>" id="notification-row-<%= item.id %>">
          
          <div class="d-flex align-items-start gap-3">
            <!-- Icon by type -->
            <div class="fs-4 mt-0.5">
              <% if (item.type === 'inspection_fail') { %>
                <i class="bi bi-exclamation-triangle-fill text-danger" title="พบความผิดปกติ"></i>
              <% } else if (item.type === 'daily_summary') { %>
                <i class="bi bi-clipboard-data-fill text-success" title="สรุปประจำวัน"></i>
              <% } else { %>
                <i class="bi bi-info-circle-fill text-info" title="ทั่วไป"></i>
              <% } %>
            </div>

            <!-- Content details -->
            <div>
              <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                <h6 class="fw-bold mb-0 <%= item.is_read ? 'text-dark' : 'text-primary' %>">
                  <%= item.title %>
                </h6>
                <% if (!item.is_read) { %>
                  <span class="badge bg-primary text-white fs-9 px-2 py-0.5 rounded-pill">ใหม่</span>
                <% } %>
                <span class="badge <%= item.type === 'inspection_fail' ? 'bg-danger-subtle text-danger border border-danger-subtle' : 'bg-success-subtle text-success border border-success-subtle' %> fs-9 rounded-3">
                  <%= item.type === 'inspection_fail' ? 'พบความผิดปกติ' : 'สรุปงานประจำวัน' %>
                </span>
              </div>
              <p class="text-secondary small mb-1" style="white-space: pre-line;"><%= item.message %></p>
              <small class="text-muted fs-8.5"><i class="bi bi-clock me-1"></i><%= formatThaiDate(item.created_at, true) %></small>
            </div>
          </div>

          <!-- Actions -->
          <div class="d-flex align-items-center gap-1.5">
            <% if (!item.is_read) { %>
              <button onclick="markSingleAsRead(<%= item.id %>)" class="btn btn-sm btn-light border text-primary px-2.5 py-1.5 rounded-3" title="ทำเครื่องหมายว่าอ่านแล้ว">
                <i class="bi bi-check-lg"></i>
              </button>
            <% } %>
            <button onclick="deleteNotification(<%= item.id %>)" class="btn btn-sm btn-light border text-danger px-2.5 py-1.5 rounded-3" title="ลบการแจ้งเตือน">
              <i class="bi bi-trash"></i>
            </button>
          </div>

        </div>
      <% }) %>
    <% } else { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-bell-slash fs-1 mb-2 d-block text-secondary opacity-50"></i>
        ยังไม่มีรายการแจ้งเตือนในระบบ
      </div>
    <% } %>
  </div>

  <!-- PAGINATION -->
  <% if (pagination && pagination.totalPages > 1) { %>
    <nav aria-label="Page navigation" class="mt-4">
      <ul class="pagination pagination-sm justify-content-center mb-0">
        <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
          <a class="page-link py-2 px-3" href="?page=<%= pagination.page - 1 %>">ย้อนกลับ</a>
        </li>
        <% for(let i = 1; i <= pagination.totalPages; i++) { %>
          <li class="page-item <%= pagination.page == i ? 'active' : '' %>">
            <a class="page-link py-2 px-3" href="?page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
          <a class="page-link py-2 px-3" href="?page=<%= pagination.page + 1 %>">ถัดไป</a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>

<style>
.fs-8.5 {
  font-size: 0.85rem;
}
.fs-9 {
  font-size: 0.72rem;
}
.transition-all {
  transition: all 0.2s ease-in-out;
}
.rounded-4 {
  border-radius: 12px !important;
}
.rounded-3 {
  border-radius: 8px !important;
}
.bg-primary-subtle {
  background-color: var(--bs-primary-bg-subtle) !important;
}
</style>

<script>
  // Mark a single notification as read
  function markSingleAsRead(id) {
    fetch(`/notifications/api/${id}/read`, {
      method: 'POST'
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        // Update row visual state
        const row = document.getElementById(`notification-row-${id}`);
        if (row) {
          row.classList.remove('bg-primary-subtle', 'bg-opacity-25', 'border-start', 'border-primary', 'border-3');
          row.classList.add('bg-white');
          // Remove read check button
          const checkBtn = row.querySelector('.text-primary');
          if (checkBtn) checkBtn.remove();
          // Remove "new" badge
          const newBadge = row.querySelector('.badge.bg-primary');
          if (newBadge) newBadge.remove();
        }
        // Refresh navbar count badge
        if (typeof fetchUnreadNotificationCount === 'function') {
          fetchUnreadNotificationCount();
        }
      }
    })
    .catch(err => console.error('Error marking notification as read:', err));
  }

  // Mark all notifications as read
  function markAllNotificationsAsRead() {
    Swal.fire({
      title: 'ทำเครื่องหมายว่าอ่านหมดแล้ว?',
      text: 'คุณต้องการเปลี่ยนสถานะการแจ้งเตือนทั้งหมดให้เป็น "อ่านแล้ว" ใช่หรือไม่?',
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#3085d6',
      cancelButtonColor: '#d33',
      confirmButtonText: 'ใช่, ทั้งหมด',
      cancelButtonText: 'ยกเลิก'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch('/notifications/api/read-all', {
          method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            window.location.reload();
          }
        })
        .catch(err => console.error('Error marking all notifications as read:', err));
      }
    });
  }

  // Delete notification
  function deleteNotification(id) {
    Swal.fire({
      title: 'ยืนยันการลบแจ้งเตือน?',
      text: 'คุณต้องการลบข้อความการแจ้งเตือนนี้ออกจากระบบใช่หรือไม่?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#3085d6',
      confirmButtonText: 'ใช่, ลบออก',
      cancelButtonText: 'ยกเลิก'
    }).then((result) => {
      if (result.isConfirmed) {
        fetch(`/notifications/api/${id}/delete`, {
          method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            // Remove row from DOM with visual fade
            const row = document.getElementById(`notification-row-${id}`);
            if (row) {
              row.style.opacity = 0;
              setTimeout(() => {
                row.remove();
                // Check if list is empty, reload to show empty state
                const list = document.getElementById('notificationListGroup');
                if (list && list.children.length === 0) {
                  window.location.reload();
                }
              }, 200);
            }
            if (typeof fetchUnreadNotificationCount === 'function') {
              fetchUnreadNotificationCount();
            }
          }
        })
        .catch(err => console.error('Error deleting notification:', err));
      }
    });
  }
</script>

<%- include('../layouts/footer') %>

<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
  <div>
    <h1 class="h2 fw-bold text-dark">Physical Servers & Network Devices</h1>
    <p class="text-muted small">ระบบบริหารจัดการเครื่องเซิร์ฟเวอร์ สวิตช์ และอุปกรณ์ความปลอดภัย</p>
  </div>
  <div class="btn-toolbar mb-2 mb-md-0 gap-2">
    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#addModal">
      <i class="bi bi-plus-lg"></i> ลงทะเบียนอุปกรณ์
    </button>
    <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#importModal">
      <i class="bi bi-file-earmark-arrow-up"></i> นำเข้า CSV
    </button>
    <a href="/servers/export?search=<%= search %>&roomId=<%= roomId %>&rackId=<%= rackId %>&assetTypeId=<%= assetTypeId %>" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
      <i class="bi bi-file-earmark-arrow-down"></i> ส่งออก CSV
    </a>
  </div>
</div>

<!-- Alerts -->
<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<!-- Search bar -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-body">
    <form method="GET" action="/servers" class="row g-3">
      <!-- Search Input -->
      <div class="col-12 col-md-3">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
          <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="ชื่อ, IP, Serial..." value="<%= search %>">
        </div>
      </div>
      
      <!-- Room Filter -->
      <div class="col-12 col-sm-6 col-md-3 col-lg-2">
        <select name="roomId" id="filter_room_id" class="form-select" onchange="filterRacksByRoom(this.value)">
          <option value="">-- เลือกห้อง Server --</option>
          <% rooms.forEach(room => { %>
            <option value="<%= room.id %>" <%= roomId == room.id ? 'selected' : '' %>><%= room.room_name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Rack Filter -->
      <div class="col-12 col-sm-6 col-md-3 col-lg-2">
        <select name="rackId" id="filter_rack_id" class="form-select">
          <option value="">-- เลือกตู้ Rack --</option>
          <% racks.forEach(rack => { %>
            <option value="<%= rack.id %>" data-room-id="<%= rack.room_id %>" <%= rackId == rack.id ? 'selected' : '' %>><%= rack.rack_name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Type Filter -->
      <div class="col-12 col-sm-6 col-md-3 col-lg-2">
        <select name="assetTypeId" class="form-select">
          <option value="">-- เลือกประเภท --</option>
          <% assetTypes.forEach(type => { %>
            <option value="<%= type.id %>" <%= assetTypeId == type.id ? 'selected' : '' %>><%= type.type_name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Buttons -->
      <div class="col-12 col-sm-6 col-md-3 col-lg-3 d-flex gap-2">
        <button type="submit" class="btn btn-dark flex-grow-1">ค้นหา</button>
        <% if (search || roomId || rackId || assetTypeId) { %>
          <a href="/servers" class="btn btn-outline-secondary" title="ล้างตัวกรอง"><i class="bi bi-x-lg"></i></a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<!-- Main Table -->
<div class="card border-0 shadow-sm rounded-4 p-4">
  <div class="table-responsive">
    <table class="table align-middle table-hover">
      <thead class="table-light">
        <tr>
          <th>ชื่ออุปกรณ์</th>
          <th>ประเภท</th>
          <th>ตู้ Rack (ห้อง)</th>
          <th>IP Address</th>
          <th>Serial Number</th>
          <th>สล็อต U</th>
          <th>สถานะ</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (servers.length > 0) { %>
          <% servers.forEach(server => { %>
            <tr>
              <td>
                <span class="fw-semibold text-primary"><%= server.server_name %></span>
                <span class="d-block text-muted fs-8">Model: <%= server.model || '-' %></span>
              </td>
              <td><span class="badge bg-info-subtle text-info"><%= server.type_name %></span></td>
              <td><%= server.rack_name %> (<%= server.room_name %>)</td>
              <td><code><%= server.ip_address || '-' %></code></td>
              <td class="small"><%= server.serial_number || '-' %></td>
              <td><span class="badge bg-secondary">U<%= server.rack_position_u || '-' %></span></td>
              <td>
                <% if(server.status === 'active') { %>
                  <span class="badge bg-success">Active</span>
                <% } else if(server.status === 'maintenance') { %>
                  <span class="badge bg-warning text-dark">Maintenance</span>
                <% } else { %>
                  <span class="badge bg-danger">Inactive</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-2">
                  <button class="btn btn-sm btn-outline-warning" 
                          data-bs-toggle="modal" 
                          data-bs-target="#editModal" 
                          data-id="<%= server.id %>"
                          data-rack_id="<%= server.rack_id %>"
                          data-asset_type_id="<%= server.asset_type_id %>"
                          data-server_name="<%= server.server_name %>"
                          data-model="<%= server.model %>"
                          data-serial_number="<%= server.serial_number %>"
                          data-ip_address="<%= server.ip_address %>"
                          data-asset_number="<%= server.asset_number %>"
                          data-rack_position_u="<%= server.rack_position_u %>"
                          data-description="<%= server.description %>"
                          data-status="<%= server.status %>"
                          onclick="populateEditModal(this)">
                    <i class="bi bi-pencil"></i> แก้ไข
                  </button>
                  <button class="btn btn-sm btn-outline-danger" 
                          data-bs-toggle="modal" 
                          data-bs-target="#deleteModal" 
                          data-id="<%= server.id %>"
                          data-name="<%= server.server_name %>"
                          onclick="confirmDelete(this)">
                    <i class="bi bi-trash"></i> ลบ
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="8" class="text-center text-muted py-4">ไม่พบข้อมูลเซิร์ฟเวอร์กายภาพในระบบ</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
    <nav aria-label="Page navigation" class="mt-4">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&roomId=<%= roomId %>&rackId=<%= rackId %>&assetTypeId=<%= assetTypeId %>&page=<%= pagination.page - 1 %>">ย้อนกลับ</a>
        </li>
        <% for(let i=1; i<=pagination.totalPages; i++) { %>
          <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
            <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&roomId=<%= roomId %>&rackId=<%= rackId %>&assetTypeId=<%= assetTypeId %>&page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?search=<%= encodeURIComponent(search) %>&roomId=<%= roomId %>&rackId=<%= rackId %>&assetTypeId=<%= assetTypeId %>&page=<%= pagination.page + 1 %>">ถัดไป</a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="addModalLabel">ลงทะเบียนอุปกรณ์</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/servers" method="POST" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="server_name" class="form-label small fw-semibold">ชื่ออุปกรณ์ *</label>
              <input type="text" class="form-control" id="server_name" name="server_name" required>
              <div class="invalid-feedback">กรุณาระบุชื่ออุปกรณ์</div>
            </div>
            <div class="col-md-6">
              <label for="asset_type_id" class="form-label small fw-semibold">ประเภททรัพย์สิน *</label>
              <select class="form-select" id="asset_type_id" name="asset_type_id" required>
                <option value="">-- เลือกประเภท --</option>
                <% assetTypes.forEach(type => { %>
                  <option value="<%= type.id %>"><%= type.type_name %></option>
                <% }) %>
              </select>
              <div class="invalid-feedback">กรุณาเลือกประเภททรัพย์สิน</div>
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="rack_id" class="form-label small fw-semibold">ติดตั้งในตู้ Rack *</label>
              <select class="form-select" id="rack_id" name="rack_id" required>
                <option value="">-- เลือกตู้ Rack --</option>
                <% racks.forEach(rack => { %>
                  <option value="<%= rack.id %>"><%= rack.rack_name %> (<%= rack.room_name %>)</option>
                <% }) %>
              </select>
              <div class="invalid-feedback">กรุณาเลือกตู้ Rack</div>
            </div>
            <div class="col-md-6">
              <label for="rack_position_u" class="form-label small fw-semibold">ตำแหน่งติดตั้ง (U Slot)</label>
              <input type="number" class="form-control" id="rack_position_u" name="rack_position_u" min="1" max="100">
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="ip_address" class="form-label small fw-semibold">IP Address</label>
              <input type="text" class="form-control" id="ip_address" name="ip_address" placeholder="10.200.x.x">
            </div>
            <div class="col-md-6">
              <label for="model" class="form-label small fw-semibold">ยี่ห้อ / รุ่น</label>
              <input type="text" class="form-control" id="model" name="model">
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="serial_number" class="form-label small fw-semibold">Serial Number</label>
              <input type="text" class="form-control" id="serial_number" name="serial_number">
            </div>
            <div class="col-md-6">
              <label for="asset_number" class="form-label small fw-semibold">หมายเลขครุภัณฑ์</label>
              <input type="text" class="form-control" id="asset_number" name="asset_number">
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="status" class="form-label small fw-semibold">สถานะการทำงาน *</label>
              <select class="form-select" id="status" name="status" required>
                <option value="active" selected>Active</option>
                <option value="maintenance">Maintenance</option>
                <option value="inactive">Inactive</option>
              </select>
            </div>
          </div>

          <div class="mb-2">
            <label for="description" class="form-label small fw-semibold">รายละเอียดเพิ่มเติม</label>
            <textarea class="form-control" id="description" name="description" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-primary px-4">บันทึกข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="editModalLabel">แก้ไขอุปกรณ์</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editForm" method="POST" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="edit_server_name" class="form-label small fw-semibold">ชื่ออุปกรณ์ *</label>
              <input type="text" class="form-control" id="edit_server_name" name="server_name" required>
              <div class="invalid-feedback">กรุณาระบุชื่ออุปกรณ์</div>
            </div>
            <div class="col-md-6">
              <label for="edit_asset_type_id" class="form-label small fw-semibold">ประเภททรัพย์สิน *</label>
              <select class="form-select" id="edit_asset_type_id" name="asset_type_id" required>
                <% assetTypes.forEach(type => { %>
                  <option value="<%= type.id %>"><%= type.type_name %></option>
                <% }) %>
              </select>
              <div class="invalid-feedback">กรุณาเลือกประเภททรัพย์สิน</div>
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="edit_rack_id" class="form-label small fw-semibold">ติดตั้งในตู้ Rack *</label>
              <select class="form-select" id="edit_rack_id" name="rack_id" required>
                <% racks.forEach(rack => { %>
                  <option value="<%= rack.id %>"><%= rack.rack_name %> (<%= rack.room_name %>)</option>
                <% }) %>
              </select>
              <div class="invalid-feedback">กรุณาเลือกตู้ Rack</div>
            </div>
            <div class="col-md-6">
              <label for="edit_rack_position_u" class="form-label small fw-semibold">ตำแหน่งติดตั้ง (U Slot)</label>
              <input type="number" class="form-control" id="edit_rack_position_u" name="rack_position_u" min="1" max="100">
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="edit_ip_address" class="form-label small fw-semibold">IP Address</label>
              <input type="text" class="form-control" id="edit_ip_address" name="ip_address">
            </div>
            <div class="col-md-6">
              <label for="edit_model" class="form-label small fw-semibold">ยี่ห้อ / รุ่น</label>
              <input type="text" class="form-control" id="edit_model" name="model">
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="edit_serial_number" class="form-label small fw-semibold">Serial Number</label>
              <input type="text" class="form-control" id="edit_serial_number" name="serial_number">
            </div>
            <div class="col-md-6">
              <label for="edit_asset_number" class="form-label small fw-semibold">หมายเลขครุภัณฑ์</label>
              <input type="text" class="form-control" id="edit_asset_number" name="asset_number">
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label for="edit_status" class="form-label small fw-semibold">สถานะการทำงาน *</label>
              <select class="form-select" id="edit_status" name="status" required>
                <option value="active">Active</option>
                <option value="maintenance">Maintenance</option>
                <option value="inactive">Inactive</option>
              </select>
            </div>
          </div>

          <div class="mb-2">
            <label for="edit_description" class="form-label small fw-semibold">รายละเอียดเพิ่มเติม</label>
            <textarea class="form-control" id="edit_description" name="description" rows="2"></textarea>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-warning px-4">บันทึกการแก้ไข</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="deleteModalLabel">ยืนยันการลบ?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="deleteForm" method="POST">
        <div class="modal-body py-3">
          <p class="text-muted small mb-0">คุณแน่ใจหรือไม่ว่าต้องการลบเซิร์ฟเวอร์ <strong id="deleteItemName" class="text-dark"></strong>? การลบนี้ไม่สามารถกู้คืนข้อมูลได้</p>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-3" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-danger px-3">ลบข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="importModalLabel">นำเข้าข้อมูลด้วยไฟล์ CSV</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/servers/import" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="csvFile" class="form-label small fw-semibold">เลือกไฟล์ CSV *</label>
            <input class="form-control" type="file" id="csvFile" name="file" accept=".csv" required>
            <div class="invalid-feedback">กรุณาเลือกไฟล์ CSV ที่ต้องการนำเข้า</div>
          </div>
          <div class="p-3 bg-light rounded-3 border text-break">
            <h6 class="fw-bold fs-7 mb-2">โครงสร้างหัวตารางที่ถูกต้องของไฟล์ CSV (Headers):</h6>
            <code class="small d-block text-dark">rack_id,asset_type_id,server_name,model,serial_number,ip_address,asset_number,rack_position_u,description,status</code>
            <span class="d-block text-muted fs-8 mt-2">* หมายเหตุ: rack_id, asset_type_id, server_name ห้ามเว้นว่าง</span>
          </div>
        </div>
        <div class="modal-footer border-top-0 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-success px-4">เริ่มนำเข้าข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict'
  var forms = document.querySelectorAll('.needs-validation')
  Array.prototype.slice.call(forms)
    .forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
})()

function populateEditModal(btn) {
  const id = btn.getAttribute('data-id');
  document.getElementById('editForm').action = '/servers/' + id + '/update';
  document.getElementById('edit_rack_id').value = btn.getAttribute('data-rack_id');
  document.getElementById('edit_asset_type_id').value = btn.getAttribute('data-asset_type_id');
  document.getElementById('edit_server_name').value = btn.getAttribute('data-server_name');
  document.getElementById('edit_model').value = btn.getAttribute('data-model') || '';
  document.getElementById('edit_serial_number').value = btn.getAttribute('data-serial_number') || '';
  document.getElementById('edit_ip_address').value = btn.getAttribute('data-ip_address') || '';
  document.getElementById('edit_asset_number').value = btn.getAttribute('data-asset_number') || '';
  document.getElementById('edit_rack_position_u').value = btn.getAttribute('data-rack_position_u') || '';
  document.getElementById('edit_description').value = btn.getAttribute('data-description') || '';
  document.getElementById('edit_status').value = btn.getAttribute('data-status') || 'active';
}

function confirmDelete(btn) {
  const id = btn.getAttribute('data-id');
  const name = btn.getAttribute('data-name');
  document.getElementById('deleteForm').action = '/servers/' + id + '/delete';
  document.getElementById('deleteItemName').innerText = name;
}

// ── Dynamic Room & Rack Dependent Filtering ──
function filterRacksByRoom(roomId) {
  const rackSelect = document.getElementById('filter_rack_id');
  const options = rackSelect.querySelectorAll('option');
  
  rackSelect.value = ''; // Reset selection
  
  options.forEach(opt => {
    const optRoomId = opt.getAttribute('data-room-id');
    if (!roomId || !optRoomId || optRoomId === roomId) {
      opt.style.display = 'block';
    } else {
      opt.style.display = 'none';
    }
  });
}

// Keep filtered state active on page load if Room filter is selected
document.addEventListener('DOMContentLoaded', function() {
  const filterRoom = document.getElementById('filter_room_id');
  if (filterRoom && filterRoom.value) {
    const rackSelect = document.getElementById('filter_rack_id');
    const selectedRackVal = "<%= rackId %>";
    
    const options = rackSelect.querySelectorAll('option');
    options.forEach(opt => {
      const optRoomId = opt.getAttribute('data-room-id');
      if (!optRoomId || optRoomId === filterRoom.value) {
        opt.style.display = 'block';
      } else {
        opt.style.display = 'none';
      }
    });
    rackSelect.value = selectedRackVal;
  }
});
</script>


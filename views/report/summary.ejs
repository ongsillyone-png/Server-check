<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>รายงานสรุปผลการเดินตรวจเช็คห้อง Server</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Google Fonts - Sarabun -->
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Sarabun', sans-serif;
      background-color: #fff;
    }
    @media print {
      .no-print {
        display: none !important;
      }
      body {
        font-size: 12px;
      }
    }
  </style>
</head>
<body class="py-5">

  <div class="container">
    <!-- Action buttons for print -->
    <div class="d-flex justify-content-between align-items-center mb-5 no-print bg-light p-3 rounded border">
      <div>
        <h5 class="fw-bold mb-0">รายงานพร้อมพิมพ์</h5>
        <span class="text-muted small">คลิกปุ่มด้านขวาเพื่อเปิดหน้าต่างพิมพ์เอกสารรายงาน</span>
      </div>
      <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-primary"><i class="bi bi-printer"></i> พิมพ์รายงาน (Print)</button>
        <button onclick="window.close()" class="btn btn-outline-secondary">ปิดหน้านี้</button>
      </div>
    </div>

    <!-- Printable Report Document -->
    <div class="text-center mb-5 border-bottom pb-4">
      <h2 class="fw-bold">รายงานสรุปผลการเดินตรวจเช็คห้อง Server</h2>
      <h5 class="text-muted">โรงพยาบาลศูนย์บริการสุขภาพส่วนกลาง</h5>
      <p class="mb-0 text-secondary">ข้อมูล ณ วันที่ 01 กรกฎาคม 2026 - 03 กรกฎาคม 2026</p>
    </div>

    <!-- Info Section -->
    <div class="row mb-4">
      <div class="col-6">
        <strong>หน่วยงานผู้จัดทำ:</strong> ศูนย์สารสนเทศและการสื่อสารข้อมูล<br>
        <strong>ผู้ตรวจเช็คหลัก:</strong> นายสมศักดิ์ รักงาน (เจ้าหน้าที่ระบบ)
      </div>
      <div class="col-6 text-end">
        <strong>วันที่พิมพ์รายงาน:</strong> 03 กรกฎาคม 2026<br>
        <strong>เวลาที่พิมพ์:</strong> 22:00 น.
      </div>
    </div>

    <!-- Summary Details Table -->
    <table class="table table-bordered align-middle">
      <thead class="table-light">
        <tr>
          <th>วันที่ตรวจ</th>
          <th>ห้อง Server</th>
          <th>ตู้ Rack</th>
          <th>เซิร์ฟเวอร์กายภาพ</th>
          <th>สถานะผลการตรวจ</th>
          <th>หมายเหตุ/ข้อบกพร่อง</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>02/07/2026</td>
          <td>Main Server Room A</td>
          <td>Rack A-01</td>
          <td>HIS-DB-01</td>
          <td class="text-success fw-bold">ผ่าน (PASS)</td>
          <td>การระบายอากาศและอุณหภูมิปกติ (21.5°C)</td>
        </tr>
        <tr>
          <td>02/07/2026</td>
          <td>Main Server Room A</td>
          <td>Rack A-02</td>
          <td>Core-Switch-01</td>
          <td class="text-warning fw-bold">เตือน (WARNING)</td>
          <td>ฝุ่นเกาะบริเวณช่องระบายพัดลมด้านหลังตู้แร็ค</td>
        </tr>
      </tbody>
    </table>

    <div class="row mt-5 pt-5 text-center">
      <div class="col-6">
        <p class="mb-5">ลงชื่อ..........................................................<br>ผู้รายงาน/ผู้ตรวจเช็ค</p>
      </div>
      <div class="col-6">
        <p class="mb-5">ลงชื่อ..........................................................<br>หัวหน้าฝ่ายสารสนเทศโรงพยาบาล</p>
      </div>
    </div>
  </div>

</body>
</html>

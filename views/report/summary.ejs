<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<%
  let reportTitle = '';
  let iconClass = '';
  if (summaryType === 'server') {
    reportTitle = 'รายงานสรุปผลการเดินตรวจรายเครื่องเซิร์ฟเวอร์';
    iconClass = 'bi-server';
  } else if (summaryType === 'rack') {
    reportTitle = 'รายงานสรุปผลการเดินตรวจรายตู้แร็ค (Racks)';
    iconClass = 'bi-hdd-rack';
  } else if (summaryType === 'room') {
    reportTitle = 'รายงานสรุปผลการเดินตรวจรายห้อง Server';
    iconClass = 'bi-door-closed';
  } else if (summaryType === 'user') {
    reportTitle = 'รายงานสรุปผลการเข้าปฏิบัติงานเดินตรวจรายบุคคล';
    iconClass = 'bi-people';
  }
%>

<div class="print-container">
  <!-- HEADER CONTROLS (HIDDEN ON PRINT) -->
  <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom no-print">
    <div>
      <h1 class="h2 fw-bold text-dark"><i class="bi <%= iconClass %> text-primary me-2"></i><%= reportTitle %></h1>
      <p class="text-muted small mb-0">รายงานสถิติตัวเลขข้อบกพร่องสะสม อัตราการตรวจผ่าน และภาระงานเดินตรวจของระบบสารสนเทศ</p>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0 gap-2">
      <a href="/reports" class="btn btn-outline-secondary d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
        <i class="bi bi-arrow-left"></i> ย้อนกลับ
      </a>
      <button type="button" onclick="window.print()" class="btn btn-outline-primary d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
        <i class="bi bi-printer"></i> สั่งพิมพ์ / บันทึก PDF
      </button>
      <button type="button" onclick="exportSummaryCSV()" class="btn btn-outline-success d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
        <i class="bi bi-file-earmark-excel"></i> ส่งออกไฟล์ CSV
      </button>
    </div>
  </div>

  <!-- FORMAL PRINT HEADER (ONLY VISIBLE ON PRINT) -->
  <div class="only-print text-center mb-4">
    <h3 class="fw-bold mb-1"><%= reportTitle %></h3>
    <h5 class="text-muted mb-2">โรงพยาบาลศูนย์บริการสุขภาพส่วนกลาง</h5>
    <div class="small fw-semibold text-dark">
      พิมพ์รายงาน ณ วันที่: <%= formatThaiDate(new Date().toISOString(), true) %>
    </div>
    <hr class="border-secondary my-3">
  </div>

  <!-- SUMMARY GRID CARD -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 print-card">
    <h5 class="fw-bold text-dark mb-3 no-print"><i class="bi bi-table text-primary me-2"></i>ตารางข้อมูลสรุปสะสม</h5>
    
    <div class="table-responsive">
      <table class="table align-middle table-hover table-bordered mb-0">
        <thead class="table-light">
          <!-- SERVER HEADERS -->
          <% if (summaryType === 'server') { %>
            <tr>
              <th>เครื่องเซิร์ฟเวอร์</th>
              <th>Model / IP Address</th>
              <th>พิกัด (ตู้แร็ค / ห้อง)</th>
              <th class="text-center" style="width: 10%;">ตรวจทั้งหมด (ครั้ง)</th>
              <th class="text-center text-success" style="width: 10%;">ปกติ (PASS)</th>
              <th class="text-center text-warning" style="width: 10%;">เฝ้าระวัง (WARN)</th>
              <th class="text-center text-danger" style="width: 10%;">ผิดปกติ (FAIL)</th>
              <th class="text-center" style="width: 10%;">อัตราปกติ</th>
            </tr>
          <!-- RACK HEADERS -->
          <% } else if (summaryType === 'rack') { %>
            <tr>
              <th>ตู้แร็ค (Rack)</th>
              <th>ห้อง Server ที่ติดตั้ง</th>
              <th class="text-center" style="width: 15%;">ตรวจอุปกรณ์สะสม (ครั้ง)</th>
              <th class="text-center text-success" style="width: 15%;">ปกติ (PASS)</th>
              <th class="text-center text-warning" style="width: 15%;">เฝ้าระวัง (WARN)</th>
              <th class="text-center text-danger" style="width: 15%;">ผิดปกติ (FAIL)</th>
              <th class="text-center" style="width: 12%;">อัตราปกติ</th>
            </tr>
          <!-- ROOM HEADERS -->
          <% } else if (summaryType === 'room') { %>
            <tr>
              <th>ห้อง Server</th>
              <th>พิกัดกายภาพ (อาคาร / ชั้น)</th>
              <th class="text-center" style="width: 15%;">ตรวจอุปกรณ์สะสม (ครั้ง)</th>
              <th class="text-center text-success" style="width: 15%;">ปกติ (PASS)</th>
              <th class="text-center text-warning" style="width: 15%;">เฝ้าระวัง (WARN)</th>
              <th class="text-center text-danger" style="width: 15%;">ผิดปกติ (FAIL)</th>
              <th class="text-center" style="width: 12%;">อัตราปกติ</th>
            </tr>
          <!-- USER HEADERS -->
          <% } else if (summaryType === 'user') { %>
            <tr>
              <th>ชื่อผู้ปฏิบัติงาน</th>
              <th>Username</th>
              <th>สิทธิ์การใช้งาน (Role)</th>
              <th class="text-center" style="width: 25%;">จำนวนรอบที่เดินตรวจเช็คสำเร็จ (รอบ)</th>
            </tr>
          <% } %>
        </thead>
        <tbody>
          <% if (data && data.length > 0) { %>
            <% data.forEach(row => { %>
              
              <!-- SERVER ROWS -->
              <% if (summaryType === 'server') { %>
                <% 
                  const rate = row.total_inspected > 0 
                    ? ((row.pass_count / row.total_inspected) * 100).toFixed(1) 
                    : '0.0';
                %>
                <tr>
                  <td><strong><%= row.server_name %></strong></td>
                  <td>
                    <span class="small text-muted d-block">Model: <%= row.model || '-' %></span>
                    <span class="small text-secondary d-block">IP: <%= row.ip_address || '-' %></span>
                  </td>
                  <td>
                    <span class="small text-muted d-block">ห้อง: <%= row.room_name %></span>
                    <span class="small text-secondary d-block">แร็ค: <%= row.rack_name %></span>
                  </td>
                  <td class="text-center"><%= row.total_inspected %></td>
                  <td class="text-center text-success"><%= row.pass_count %></td>
                  <td class="text-center text-warning"><%= row.warn_count %></td>
                  <td class="text-center text-danger"><%= row.fail_count %></td>
                  <td class="text-center font-monospace">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-3"><%= rate %>%</span>
                  </td>
                </tr>

              <!-- RACK ROWS -->
              <% } else if (summaryType === 'rack') { %>
                <% 
                  const rate = row.total_inspected > 0 
                    ? ((row.pass_count / row.total_inspected) * 100).toFixed(1) 
                    : '0.0';
                %>
                <tr>
                  <td><strong><%= row.rack_name %></strong></td>
                  <td><%= row.room_name %></td>
                  <td class="text-center"><%= row.total_inspected %></td>
                  <td class="text-center text-success"><%= row.pass_count %></td>
                  <td class="text-center text-warning"><%= row.warn_count %></td>
                  <td class="text-center text-danger"><%= row.fail_count %></td>
                  <td class="text-center font-monospace">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-3"><%= rate %>%</span>
                  </td>
                </tr>

              <!-- ROOM ROWS -->
              <% } else if (summaryType === 'room') { %>
                <% 
                  const rate = row.total_inspected > 0 
                    ? ((row.pass_count / row.total_inspected) * 100).toFixed(1) 
                    : '0.0';
                %>
                <tr>
                  <td><strong><%= row.room_name %></strong></td>
                  <td>อาคาร: <%= row.building %>, ชั้น: <%= row.floor %></td>
                  <td class="text-center"><%= row.total_inspected %></td>
                  <td class="text-center text-success"><%= row.pass_count %></td>
                  <td class="text-center text-warning"><%= row.warn_count %></td>
                  <td class="text-center text-danger"><%= row.fail_count %></td>
                  <td class="text-center font-monospace">
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-3"><%= rate %>%</span>
                  </td>
                </tr>

              <!-- USER ROWS -->
              <% } else if (summaryType === 'user') { %>
                <tr>
                  <td><strong><%= row.user_name %></strong></td>
                  <td><code><%= row.username %></code></td>
                  <td><span class="badge bg-secondary-subtle text-dark border rounded-3 px-2 py-1"><%= row.role_name %></span></td>
                  <td class="text-center fw-bold text-primary fs-6"><%= row.completed_sessions %></td>
                </tr>
              <% } %>

            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="<%= summaryType === 'server' ? 8 : (summaryType === 'user' ? 4 : 7) %>" class="text-center py-5 text-muted">
                <i class="bi bi-clipboard-x fs-1 mb-2 d-block text-secondary opacity-50"></i>
                ไม่พบข้อมูลสถิติประวัติสะสม
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- FORMAL SIGNATURE BLOCKS (ONLY VISIBLE ON PRINT) -->
    <div class="only-print row mt-5 pt-4 text-center">
      <div class="col-6">
        <div class="mb-5 text-muted small">ลงชื่อ.............................................................. ผู้ออกรายงาน</div>
        <div>(......................................................................)</div>
        <div class="small text-muted mt-1">ตำแหน่ง เจ้าหน้าที่ผู้เดินตรวจระบบ</div>
      </div>
      <div class="col-6">
        <div class="mb-5 text-muted small">ลงชื่อ.............................................................. ผู้รับรองรายงาน</div>
        <div>(......................................................................)</div>
        <div class="small text-muted mt-1">ตำแหน่ง หัวหน้าฝ่ายเทคโนโลยีสารสนเทศ</div>
      </div>
    </div>
  </div>
</div>

<style>
.rounded-4 {
  border-radius: 12px !important;
}
.rounded-3 {
  border-radius: 8px !important;
}

/* PRINT LAYOUT CUSTOM STYLES */
@media print {
  body {
    background-color: #fff !important;
    color: #000 !important;
    font-size: 11pt !important;
  }
  .no-print {
    display: none !important;
  }
  header, nav, .sidebar-wrapper, .navbar, .btn, .no-print, form {
    display: none !important;
  }
  main, .col-md-9, .col-lg-10, .print-container, .print-card {
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
  }
  .print-card {
    background: transparent !important;
    padding: 0 !important;
  }
  .table {
    width: 100% !important;
    border-collapse: collapse !important;
  }
  .table th, .table td {
    border: 1px solid #000 !important;
    padding: 6px !important;
    color: #000 !important;
    font-size: 10pt !important;
  }
  .badge {
    border: none !important;
    background: transparent !important;
    color: #000 !important;
    font-weight: bold !important;
    padding: 0 !important;
  }
  .only-print {
    display: block !important;
  }
}

.only-print {
  display: none;
}
</style>

<script>
  function exportSummaryCSV() {
    window.location.href = '/reports/export?type=<%= summaryType %>';
  }
</script>

<%- include('../layouts/footer') %>

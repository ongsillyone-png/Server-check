<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="print-container">
  <!-- HEADER CONTROLS (HIDDEN ON PRINT) -->
  <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom no-print">
    <div>
      <h1 class="h2 fw-bold text-dark"><i class="bi bi-calendar-event text-primary me-2"></i>รายงานสรุปการเดินตรวจประจำวัน</h1>
      <p class="text-muted small mb-0">เรียกดูข้อมูลผลการตรวจสอบระบบแบบเจาะจงรายวัน และออกรายงานสำหรับเสนอผู้รับผิดชอบ</p>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0 gap-2">
      <a href="/reports" class="btn btn-outline-secondary d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
        <i class="bi bi-arrow-left"></i> ย้อนกลับ
      </a>
      <button type="button" onclick="window.print()" class="btn btn-outline-primary d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
        <i class="bi bi-printer"></i> สั่งพิมพ์ / บันทึก PDF
      </button>
      <button type="button" onclick="exportDailyCSV()" class="btn btn-outline-success d-flex align-items-center gap-1.5 px-3 py-2 fw-semibold rounded-3 shadow-sm">
        <i class="bi bi-file-earmark-excel"></i> ส่งออกไฟล์ CSV
      </button>
    </div>
  </div>

  <!-- DATE FILTER PANEL (HIDDEN ON PRINT) -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 no-print">
    <form method="GET" action="/reports/daily" class="row g-3 align-items-end">
      <div class="col-12 col-md-4">
        <label for="date" class="form-label small fw-semibold text-muted">กรุณาเลือกวันที่ต้องการออกรายงาน</label>
        <input type="date" class="form-control" id="date" name="date" value="<%= date %>" required>
      </div>
      <div class="col-12 col-md-3">
        <button type="submit" class="btn btn-primary w-100 fw-semibold"><i class="bi bi-filter me-1.5"></i>ค้นหาและกรองรายงาน</button>
      </div>
    </form>
  </div>

  <!-- FORMAL PRINT HEADER (ONLY VISIBLE ON PRINT) -->
  <div class="only-print text-center mb-4">
    <h3 class="fw-bold mb-1">รายงานสรุปผลการเดินตรวจเช็คระบบคอมพิวเตอร์และเซิร์ฟเวอร์</h3>
    <h5 class="text-muted mb-2">โรงพยาบาลศูนย์บริการสุขภาพส่วนกลาง</h5>
    <div class="small fw-semibold text-dark">
      ประจำวันที่: <%= formatThaiDate(date + 'T00:00:00', false) %>
    </div>
    <hr class="border-secondary my-3">
  </div>

  <!-- DAILY RESULTS TABLE -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 print-card">
    <h5 class="fw-bold text-dark mb-3 no-print"><i class="bi bi-table text-primary me-2"></i>ตารางรายงานสรุปวันที่ <%= formatThaiDate(date + 'T00:00:00', false) %></h5>
    <div class="table-responsive">
      <table class="table align-middle table-hover table-bordered mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 10%;">รอบตรวจ</th>
            <th style="width: 20%;">เวลาที่ส่งมอบงาน</th>
            <th style="width: 15%;">ผู้ตรวจสอบ</th>
            <th style="width: 20%;">เซิร์ฟเวอร์</th>
            <th style="width: 15%;">ห้อง / ตู้แร็ค</th>
            <th style="width: 10%;" class="text-center">สถานะ</th>
            <th style="width: 20%;">หมายเหตุ</th>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length > 0) { %>
            <% data.forEach(row => { %>
              <tr>
                <td><span class="fw-bold">#<%= row.session_id %></span></td>
                <td><%= formatThaiDate(row.completed_at, true) %></td>
                <td><strong><%= row.inspector_name %></strong></td>
                <td><span class="fw-semibold"><%= row.server_name %></span></td>
                <td>
                  <span class="small text-muted d-block"><%= row.room_name %></span>
                  <span class="small text-secondary d-block">ตู้: <%= row.rack_name %></span>
                </td>
                <td class="text-center">
                  <% if (row.overall_status === 'pass') { %>
                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">ปกติ</span>
                  <% } else if (row.overall_status === 'warning') { %>
                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill">เฝ้าระวัง</span>
                  <% } else if (row.overall_status === 'fail') { %>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">ผิดปกติ</span>
                  <% } else { %>
                    <span class="badge bg-secondary-subtle text-muted rounded-pill"><%= row.overall_status %></span>
                  <% } %>
                </td>
                <td class="small text-muted"><%= row.server_remark || '-' %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-clipboard-x fs-1 mb-2 d-block text-secondary opacity-50"></i>
                ไม่พบข้อมูลรอบการเดินตรวจหรือการรายงานความผิดปกติในวันที่เลือก
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- FORMAL SIGNATURE BLOCKS (ONLY VISIBLE ON PRINT) -->
    <div class="only-print row mt-5 pt-4 text-center">
      <div class="col-6">
        <div class="mb-5 text-muted small">ลงชื่อ.............................................................. ผู้ตรวจรายงาน</div>
        <div>(......................................................................)</div>
        <div class="small text-muted mt-1">ตำแหน่ง เจ้าหน้าที่ผู้เดินตรวจระบบ</div>
      </div>
      <div class="col-6">
        <div class="mb-5 text-muted small">ลงชื่อ.............................................................. ผู้รับรองรายงาน</div>
        <div>(......................................................................)</div>
        <div class="small text-muted mt-1">ตำแหน่ง หัวหน้าฝ่ายเทคโนโลยีสารสนเทศ</div>
      </div>
    </div>
  </div>
</div>

<style>
.rounded-4 {
  border-radius: 12px !important;
}

/* PRINT LAYOUT CUSTOM STYLES */
@media print {
  body {
    background-color: #fff !important;
    color: #000 !important;
    font-size: 11pt !important;
  }
  .no-print {
    display: none !important;
  }
  /* Hide sidebar and navbar wrappers */
  header, nav, .sidebar-wrapper, .navbar, .btn, .no-print, form {
    display: none !important;
  }
  /* Expand main content area to full page */
  main, .col-md-9, .col-lg-10, .print-container, .print-card {
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
  }
  .print-card {
    background: transparent !important;
    padding: 0 !important;
  }
  .table {
    width: 100% !important;
    border-collapse: collapse !important;
  }
  .table th, .table td {
    border: 1px solid #000 !important;
    padding: 6px !important;
    color: #000 !important;
    font-size: 10pt !important;
  }
  .badge {
    border: none !important;
    background: transparent !important;
    color: #000 !important;
    font-weight: bold !important;
    padding: 0 !important;
  }
  .only-print {
    display: block !important;
  }
}

/* Hide formal print elements in standard web browser layout */
.only-print {
  display: none;
}
</style>

<script>
  function exportDailyCSV() {
    window.location.href = '/reports/export?type=daily&date=<%= date %>';
  }
</script>

<%- include('../layouts/footer') %>

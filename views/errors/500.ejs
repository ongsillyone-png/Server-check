<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 - Internal Server Error</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body class="text-center">
  <div class="container">
    <h1 class="display-3 fw-bold text-danger">500</h1>
    <h3 class="fw-bold mb-3">ระบบทำงานขัดข้อง (Internal Server Error)</h3>
    <p class="text-muted mb-4">ขออภัย เกิดข้อผิดพลาดทางระบบกรุณาลองใหม่อีกครั้ง หรือติดต่อผู้ดูแลระบบเครือข่าย</p>
    
    <% if (typeof error !== 'undefined' && error.message) { %>
      <div class="card border-danger text-start bg-danger bg-opacity-10 mb-4 mx-auto p-3 max-w-600">
        <h6 class="fw-bold text-danger">Error Debug Details:</h6>
        <code class="small text-dark"><%= error.message %></code>
        <% if (error.stack) { %>
          <pre class="small text-muted mt-2 mb-0" style="max-height: 150px; overflow-y: auto;"><code><%= error.stack %></code></pre>
        <% } %>
      </div>
    <% } %>
    
    <a href="/dashboard" class="btn btn-primary px-4 py-2">กลับไปยัง Dashboard</a>
  </div>
</body>
</html>

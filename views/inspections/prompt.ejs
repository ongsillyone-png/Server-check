<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
  <div class="card border-0 shadow-sm rounded-4 p-5 text-center" style="max-width: 500px;">
    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-4 d-inline-flex mb-4">
      <i class="bi bi-clipboard2-check fs-1"></i>
    </div>
    <h3 class="fw-bold mb-2">เริ่มเดินตรวจเช็คห้อง Server</h3>
    <p class="text-muted small mb-4">ระบบไม่พบรอบตรวจเช็คที่ค้างอยู่ของคุณในขณะนี้ กรุณากดเริ่มรอบตรวจเช็คใหม่เพื่อเข้าสู่หน้าจอกลุ่มงานและเครื่องเซิร์ฟเวอร์ที่รับผิดชอบ</p>
    
    <form action="/inspections/start" method="POST">
      <button type="submit" class="btn btn-primary btn-lg w-100 py-2.5 rounded-3 fw-bold d-flex align-items-center justify-content-center gap-2">
        <i class="bi bi-play-fill fs-5"></i> เริ่มรอบการเดินตรวจ
      </button>
    </form>
    
    <a href="/dashboard" class="btn btn-link text-muted small mt-3">กลับไปยัง Dashboard</a>
  </div>
</div>

<%- include('../layouts/footer') %>
